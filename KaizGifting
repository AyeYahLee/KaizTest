--// STOP FLAG
local StopGift = false

--// STRICT PET SCAN (NO RANDOM WORLD STUFF)
local function GetPets()
    local found = {}

    local roots = {
        LocalPlayer:FindFirstChild("Backpack"),
        LocalPlayer:FindFirstChild("Inventory"),
        LocalPlayer:FindFirstChild("PlayerGui")
    }

    for _,root in pairs(roots) do
        if root then
            for _,obj in pairs(root:GetDescendants()) do

                local name = obj.Name

                local isUUID = typeof(name) == "string"
                    and string.match(name,
                    "%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x")

                if isUUID then
                    table.insert(found, name)
                end
            end
        end
    end

    return found
end

--// LOAD PET TAB
local function LoadPets()

    for _,v in pairs(scroll:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end

    local pets = GetPets()

    if #pets == 0 then
        local t = Instance.new("TextLabel")
        t.Parent = scroll
        t.Size = UDim2.new(1,0,0,40)
        t.BackgroundTransparency = 1
        t.Text = "No pets found"
        t.TextColor3 = Color3.new(1,1,1)
        return
    end

    for _,uuid in ipairs(pets) do
        local btn = Instance.new("TextButton")
        btn.Parent = scroll
        btn.Size = UDim2.new(1,-10,0,40)
        btn.Text = uuid
        btn.BackgroundColor3 = Color3.fromRGB(45,45,45)
        btn.TextColor3 = Color3.new(1,1,1)
        btn.TextScaled = true

        btn.MouseButton1Click:Connect(function()
            uuidBox.Text = uuid
            status.Text = "Selected"
        end)
    end

    task.wait()
    scroll.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y + 10)
end

LoadPets()

--// STOP
stopBtn.MouseButton1Click:Connect(function()
    StopGift = true
    status.Text = "Stopped"
end)

--// START
startBtn.MouseButton1Click:Connect(function()

    StopGift = false

    local username = userBox.Text
    local target = Players:FindFirstChild(username)

    if not target then
        status.Text = "Player not found"
        return
    end

    --// ALL MODE
    if mode == "ALL" then

        local pets = GetPets()
        status.Text = "Found "..#pets

        for i,uuid in ipairs(pets) do
            if StopGift then break end

            pcall(function()
                GiftRemote:FireServer(target, "Entity", uuid)
            end)

            status.Text = "Gifted "..i.."/"..#pets
            task.wait(0.3)
        end

        status.Text = "Done"

    else
        --// UUID MODE

        local uuid = uuidBox.Text
        if uuid == "" then
            status.Text = "No UUID"
            return
        end

        GiftRemote:FireServer(target, "Entity", uuid)
        status.Text = "UUID gifted"
    end
end)
