-- PLAYER LIST
-- ==========================================
local function updatePlayers()
    for _, v in ipairs(scroll:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            local b = Instance.new("TextButton", scroll)
            b.Size = UDim2.new(1, 0, 0, 32)
            b.Text = p.Name
            b.BackgroundColor3 = (targetName == p.Name)
                and Color3.fromRGB(0, 120, 200)
                or  Color3.fromRGB(50, 50, 50)
            b.TextColor3 = Color3.new(1, 1, 1)
            b.Font = Enum.Font.Gotham
            b.TextSize = 13
            b.BorderSizePixel = 0
            Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
            b.MouseButton1Click:Connect(function()
                targetName = p.Name
                updatePlayers()
            end)
        end
    end
end

Players.PlayerAdded:Connect(updatePlayers)
Players.PlayerRemoving:Connect(updatePlayers)
updatePlayers()

-- ==========================================
-- HELPERS
-- ==========================================
local function setStatus(text, color)
    statusLabel.Text = text
    statusLabel.TextColor3 = color or Color3.fromRGB(180, 180, 180)
end

local function Rejoin()
    setStatus("Rejoining...", Color3.fromRGB(255, 160, 50))
    TPService:Teleport(game.PlaceId, player)
end

local function getBackpackCount()
    local count = 0
    local bp = player:FindFirstChild("Backpack")
    local char = player.Character
    if bp then
        for _, t in ipairs(bp:GetChildren()) do
            if t:IsA("Tool") and t.Name ~= "Treadmill" then count += 1 end
        end
    end
    if char then
        for _, t in ipairs(char:GetChildren()) do
            if t:IsA("Tool") and t.Name ~= "Treadmill" then count += 1 end
        end
    end
    return count
end

local function manageTools()
    local char = player.Character
    if not char then return end
    local holding = false
    for _, t in ipairs(char:GetChildren()) do
        if t:IsA("Tool") and t.Name ~= "Treadmill" then holding = true; break end
    end
    if not holding then
        local bp = player:FindFirstChild("Backpack")
        if bp then
            for _, t in ipairs(bp:GetChildren()) do
                if t:IsA("Tool") and t.Name ~= "Treadmill" then
                    t.Parent = char; break
                end
            end
        end
    end
end

local function tpTo(cf)
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    TweenService:Create(hrp, tweenInfo, {CFrame = cf}):Play()
    task.wait(0.05)
end

local function giftToTarget()
    local target = Players:FindFirstChild(targetName)
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") or not hrp then
        return false
    end
    -- TP next to target
    local targetHRP = target.Character.HumanoidRootPart
    tpTo(targetHRP.CFrame * CFrame.new(0, 0, 3))

    manageTools()

    -- Keep pressing E until confirm dialog appears (max 3 attempts)
    for attempt = 1, 3 do
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        RunService.Stepped:Wait()
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)

        -- Wait up to 1s for confirm to appear
        local elapsed = 0
        repeat
            task.wait(0.05)
            elapsed = elapsed + 0.05
            local confirmGui = playerGui:FindFirstChild("Confirm")
            if confirmGui and confirmGui.Enabled then
                local btn = confirmGui:FindFirstChild("Main", true)
                    and confirmGui.Main:FindFirstChild("ConfirmFrame", true)
                    and confirmGui.Main.ConfirmFrame:FindFirstChild("Btn_Confirm")
                if btn then
                    GuiService.SelectedObject = btn
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
                    task.wait()
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
                    GuiService.SelectedObject = nil
                    task.wait(0.08)
                    return true
                end
            end
        until elapsed >= 1
        -- Confirm didn't appear, wait a bit and retry
        task.wait(0.1)
    end
    return false
end

