-- ==========================================
-- MAIN DUPE LOOP
-- ==========================================
toggle.MouseButton1Click:Connect(function()
    isRunning = not isRunning
    toggle.Text = isRunning and "STOP" or "START"
    toggle.BackgroundColor3 = isRunning
        and Color3.fromRGB(180, 0, 0)
        or  Color3.fromRGB(0, 180, 0)

    if not isRunning then
        setStatus("Stopped", Color3.fromRGB(180, 180, 180))
        return
    end

    task.spawn(function()
        -- SLOTS 1-5 in player's chosen base
        local BASE_NAME    = "Base" .. (baseInput.Text:match("%d+") or "5")
        local TOTAL_SLOTS  = 5

        while isRunning do
            if targetName == "" then
                setStatus("⚠ Select a target player!", Color3.fromRGB(255, 80, 80))
                task.wait(1)
                continue
            end

            local modelStands = workspace:FindFirstChild("Plots")
                and workspace.Plots:FindFirstChild(BASE_NAME)
                and workspace.Plots[BASE_NAME]:FindFirstChild("ModelStands")

            if not modelStands then
                setStatus("❌ Base not found!", Color3.fromRGB(255, 80, 80))
                task.wait(1)
                continue
            end

            local allEmpty = true

            for slotNum = 1, TOTAL_SLOTS do
                if not isRunning then break end

                local stand = modelStands:FindFirstChild("ModelStand" .. slotNum)
                if not stand then
                    setStatus("Slot " .. slotNum .. " not found, skipping", Color3.fromRGB(180, 180, 180))
                    continue
                end

                -- check if slot has a pickup prompt (pet is placed there)
                local pickupPrompt = stand:FindFirstChild("PlacePoint", true)
                    and stand.PlacePoint:FindFirstChild("Att_Pickup", true)
                    and stand.PlacePoint.Att_Pickup:FindFirstChild("PickupPrompt")

                if not pickupPrompt then
                    setStatus("Slot " .. slotNum .. " empty, skipping", Color3.fromRGB(150, 150, 150))
                    task.wait(0.2)
                    continue
                end

                allEmpty = false
                setStatus("Slot " .. slotNum .. " — picking up...", Color3.fromRGB(255, 200, 50))

                -- TP to the slot
                local placePoint = stand:FindFirstChild("PlacePoint", true)
                if placePoint and placePoint:IsA("BasePart") then
                    tpTo(placePoint.CFrame + Vector3.new(0, 3, 0))
                elseif stand.PrimaryPart then
                    tpTo(stand:GetPrimaryPartCFrame() + Vector3.new(0, 3, 0))
                end

                task.wait(0.1)

                -- keep firing pickup prompt until we actually get the pet
                local countBefore = getBackpackCount()
                local pickupElapsed = 0
                repeat
                    pcall(fireproximityprompt, pickupPrompt)
                    task.wait(0.1)
                    pickupElapsed = pickupElapsed + 0.2
                until getBackpackCount() > countBefore or pickupElapsed >= 3

                setStatus("Slot " .. slotNum .. " — gifting to " .. targetName, Color3.fromRGB(100, 220, 100))

                -- gift to target
                local gifted = giftToTarget()

                if gifted then
                    -- Wait until the pickup prompt disappears (slot is cleared) before next slot
                    local waitTime = 0
                    repeat
                        task.wait(0.1)
                        waitTime = waitTime + 0.1
                        pickupPrompt = stand:FindFirstChild("PlacePoint", true)
                            and stand.PlacePoint:FindFirstChild("Att_Pickup", true)
                            and stand.PlacePoint.Att_Pickup:FindFirstChild("PickupPrompt")
                    until not pickupPrompt or waitTime >= 5
                else
                    task.wait(0.5)
                end
            end

            if allEmpty then
                setStatus("All slots empty — rejoining!", Color3.fromRGB(255, 160, 50))
                task.wait(0.5)
                Rejoin()
                break
            end

            -- after one full pass of all 5 slots, rejoin
            setStatus("All 5 slots done — rejoining!", Color3.fromRGB(255, 160, 50))
            task.wait(0.5)
            Rejoin()
            break
        end
    end)
end)
