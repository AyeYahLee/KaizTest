local SETTINGS_FILE = "AnimeSouls_ServerSettings.json"
local rejoinTimerEnabled = false
local rejoinDeadline = nil

local function saveServerSettings()
    if not writefile then return end
    local data = {
        rejoinEnabled = rejoinTimerEnabled,
        rejoinMinutes = tonumber(minutesBox.Text) or 60,
    }
    pcall(function()
        writefile(SETTINGS_FILE, HttpService:JSONEncode(data))
    end)
end

local function loadServerSettings()
    if not (isfile and readfile and isfile(SETTINGS_FILE)) then return nil end
    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(SETTINGS_FILE))
    end)
    if ok then return data end
    return nil
end

local function setRejoinTimer(enabled, mins)
    rejoinTimerEnabled = enabled
    if enabled then
        mins = mins or tonumber(minutesBox.Text) or 60
        minutesBox.Text = tostring(mins)
        rejoinDeadline = tick() + mins * 60
        timerToggleBtn.Text = "ON"
        timerToggleBtn.BackgroundColor3 = C.green
    else
        rejoinDeadline = nil
        timerToggleBtn.Text = "OFF"
        timerToggleBtn.BackgroundColor3 = C.red
        timerStatusLbl.Text = "Disabled"
    end
    saveServerSettings()
end

timerToggleBtn.MouseButton1Click:Connect(function()
    setRejoinTimer(not rejoinTimerEnabled)
end)

minutesBox.FocusLost:Connect(function()
    local mins = tonumber(minutesBox.Text) or 60
    minutesBox.Text = tostring(mins)
    if rejoinTimerEnabled then
        rejoinDeadline = tick() + mins * 60
    end
    saveServerSettings()
end)

task.spawn(function()
    while true do
        task.wait(1)
        if rejoinTimerEnabled and rejoinDeadline then
            local remaining = rejoinDeadline - tick()
            if remaining <= 0 then
                timerStatusLbl.Text = "Rejoining now..."
                rejoinSameServer()
            else
                timerStatusLbl.Text = "Rejoin in: " .. formatUptime(remaining)
            end
        end
    end
end)

-- Auto-restore saved settings from before the last rejoin/reload
