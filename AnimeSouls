local currentWorld = nil

local function getWorldName()
    local area = workspace:FindFirstChild("Area")
    if area then return area.Name end
    return tostring(workspace.DistributedGameTime)
end

local function scanMonsters()
    for _, c in pairs(checkboxes) do c:Destroy() end
    checkboxes = {}

    local found = {}
    local guiFolder = workspace:FindFirstChild("SelfGUI")
    if guiFolder then
        for _, gui in pairs(guiFolder:GetChildren()) do
            local lastName = extractNameFromGui(gui)
            if lastName and not found[lastName] then
                found[lastName] = true
            end
        end
    end

    local cm = workspace:FindFirstChild("ClientMonsters")
    if cm then
        for _, m in pairs(cm:GetChildren()) do
            if m:IsA("Model") then
                local name = getMonsterName(m, guiFolder)
                if name and not found[name] then
                    found[name] = true
                end
            end
        end
    end

    local names = {}
    for n in pairs(found) do table.insert(names, n) end
    table.sort(names)

    for i, n in ipairs(names) do
        makeCheckbox(n, i)
    end

    scroll.CanvasSize = UDim2.new(0, 0, 0, #names * 35)

    if #names > 0 then
        setStatus("Found " .. #names .. " monster type(s)", false)
    else
        setStatus("No monsters — are you in a world?", false)
    end

    currentWorld = getWorldName()
end

spawnTracked("worldWatcher", function()
    while true do
        task.wait(3)
        local w = getWorldName()
        if currentWorld and w ~= currentWorld then
            scanMonsters()
            setStatus("World changed — rescanned!", false)
        end
    end
end)

local function setFarmState(state)
    farmRunning = state
    if farmRunning then
        if next(targetNames) == nil then
            setStatus("⚠ Select at least one monster!", false)
            tween(startBtn, 0.1, {BackgroundColor3 = C.red})
            task.delay(0.5, function()
                if not farmRunning then tween(startBtn, 0.2, {BackgroundColor3 = C.accentDim}) end
            end)
            farmRunning = false
            saveSettings()
            return
        end

        tween(startBtn, 0.2, {BackgroundColor3 = C.red})
        startBtn.Text = "⏹ Stop Farming"

        local names = {}
        for n in pairs(targetNames) do table.insert(names, n) end
        setStatus("Farming (" .. targetMode .. "): " .. table.concat(names, ", "), true)

        if farmThread then task.cancel(farmThread) end
        farmThread = spawnTracked("farmLoop", farmLoop)
    else
        if farmThread then task.cancel(farmThread) end
        farmThread = nil

        tween(startBtn, 0.2, {BackgroundColor3 = C.accentDim})
        startBtn.Text = "▶ Start Farming (" .. targetMode .. ")"
        setStatus("Stopped", false)
    end

    saveSettings()
end

