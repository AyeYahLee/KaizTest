local function describeValue(v)
    if type(v) ~= "table" then return tostring(v) end
    for _, key in ipairs({"current", "count", "value", "amount"}) do
        if v[key] ~= nil then
            if v.max then return tostring(v[key]) .. "/" .. tostring(v.max) end
            return tostring(v[key])
        end
    end
    for _, val in pairs(v) do
        if type(val) == "number" then return tostring(val) end
    end
    return "{table}"
end

local function describeResult(v)
    if type(v) ~= "table" then return tostring(v) end
    local parts = {}
    for k, val in pairs(v) do
        table.insert(parts, tostring(k) .. "=" .. describeValue(val))
    end
    return "{" .. table.concat(parts, ", ") .. "}"
end

local function extractPityInfo(result)
    if type(result) ~= "table" then return nil end
    for k, v in pairs(result) do
        if tostring(k):lower():find("pity") then
            return tostring(k) .. ": " .. describeValue(v)
        end
    end
    return nil
end

local function doSpin(t)
    local ok, result = pcall(function()
        return RS.CommonLibrary.Tool.RemoteManager.Funcs.DataPullFunc:InvokeServer(t.channel, t.qty)
    end)

    if not ok then
        spinStatusLbl.Text = "Error: " .. describeResult(result):sub(1, 40)
    else
        local pity = extractPityInfo(result)
        if pity then
            t.pityText = pity
            updateRowDisplay(t)
        end
    end
    return ok, result
end

