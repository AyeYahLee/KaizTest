-- Uses the private server's actual access code (from GetJoinData) when present —
-- this is what TeleportToPlaceInstance was missing, causing Error 773 on
-- private servers. Falls back to a normal teleport for public servers.
local function rejoinSameServer()
    local placeId = game.PlaceId
    local ok, joinData = pcall(function() return lp:GetJoinData() end)
    local code = ok and joinData and joinData.PrivateServerAccessCode

    if code and code ~= "" then
        task.wait(3) -- lets the current server shut down cleanly first
        pcall(function()
            TeleportService:TeleportToPrivateServer(placeId, code, {lp})
        end)
    else
        task.wait(2)
        pcall(function() TeleportService:Teleport(placeId, lp) end)
    end
end

