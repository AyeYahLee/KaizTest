-- Turns any value into a short readable string. Tables get unwrapped one
-- level instead of printing a raw memory address, e.g. {current=1260,max=5000}
-- becomes "1260/5000".
local function describeValue(v)
    if type(v) ~= "table" then return tostring(v) end
    -- Try common nested field names first
    for _, key in ipairs({"current", "count", "value", "amount"}) do
        if v[key] ~= nil then
            if v.max then
                return tostring(v[key]) .. "/" .. tostring(v.max)
            end
            return tostring(v[key])
        end
    end
    -- Fallback: grab the first number-looking value in the table
    for _, val in pairs(v) do
        if type(val) == "number" then
            return tostring(val)
        end
    end
    return "{table}" -- last resort, at least don't show a memory address
end

local function describeResult(v)
    if type(v) ~= "table" then return tostring(v) end
    local parts = {}
    for k, val in pairs(v) do
        table.insert(parts, tostring(k) .. "=" .. describeValue(val))
    end
    return "{" .. table.concat(parts, ", ") .. "}"
end

-- Pulls a "...Pity..." field straight out of the server's own response,
-- e.g. {PityCount=1260, ...} -> "PityCount: 1260"
-- Some spin types nest it one level deeper, e.g. {PityCount={current=1260,max=5000}},
-- so we unwrap that case instead of printing the raw table address.
local function extractPityInfo(result)
    if type(result) ~= "table" then return nil end
    for k, v in pairs(result) do
        if tostring(k):lower():find("pity") then
            return tostring(k) .. ": " .. describeValue(v)
        end
    end
    return nil
end

local function doSpin(t)
    local ok, result = pcall(function()
        return RS.CommonLibrary.Tool.RemoteManager.Funcs.DataPullFunc:InvokeServer(t.channel, t.qty)
    end)
    if not ok then
        spinStatusLbl.Text = "Error: " .. describeResult(result):sub(1, 40)
    else
        local pity = extractPityInfo(result)
        if pity then
            t.pityText = pity
            updateRowDisplay(t)
        end
    end
    return ok, result
end

