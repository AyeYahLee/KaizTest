-- Server/Rejoin State
local rejoinTimerEnabled = false
local rejoinMinutes = 60
local rejoinDeadline = nil
local autoKickEnabled = true -- NEW: Auto Kick State (Defaults to true)

-- Spin State
local autoSpinEnabled = false
local spinDelay = 0.1
local selectedSpins = {}

-- Gamble State
local gambleEnabled = false
local gambleDelay = 1.5
local gamblePulls = 3

-- ── Unified Save / Load System ────────────────────────────────────
local function saveSettings()
    if not writefile then return end

    local targetsList = {}
    for name, _ in pairs(targetNames) do table.insert(targetsList, name) end

    local spinList = {}
    for channel, _ in pairs(selectedSpins) do table.insert(spinList, channel) end

    local data = {
        farmRunning = farmRunning,
        selectedMonsters = targetsList,
        rejoinEnabled = rejoinTimerEnabled,
        rejoinMinutes = rejoinMinutes,
        autoKickEnabled = autoKickEnabled, -- Saved here
        autoSpinEnabled = autoSpinEnabled,
        spinDelay = spinDelay,
        selectedSpins = spinList,
        gambleEnabled = gambleEnabled,
        gambleDelay = gambleDelay,
        gamblePulls = gamblePulls
    }

    pcall(function()
        writefile(SETTINGS_FILE, HttpService:JSONEncode(data))
    end)
end

local function loadSettings()
    if not (isfile and readfile and isfile(SETTINGS_FILE)) then return end

    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(SETTINGS_FILE))
    end)

    if ok and data then
        -- Farm
        farmRunning = data.farmRunning or false
        if data.selectedMonsters then
            for _, name in ipairs(data.selectedMonsters) do
                targetNames[name:lower()] = true
            end
        end

        -- Server
        rejoinTimerEnabled = data.rejoinEnabled or false
        rejoinMinutes = tonumber(data.rejoinMinutes) or 60
        if data.autoKickEnabled ~= nil then
            autoKickEnabled = data.autoKickEnabled
        end

        -- Spin
        autoSpinEnabled = data.autoSpinEnabled or false
        spinDelay = tonumber(data.spinDelay) or 0.1
        if data.selectedSpins then
            for _, channel in ipairs(data.selectedSpins) do
                selectedSpins[channel] = true
            end
        end

        -- Gamble
        gambleEnabled = data.gambleEnabled or false
        gambleDelay = tonumber(data.gambleDelay) or 1.5
        gamblePulls = tonumber(data.gamblePulls) or 3
    end
end

-- Global cleanup function registered for re-execution safety
_G.StopNoxarFarm = function()
    farmRunning = false
    autoSpinEnabled = false
    gambleEnabled = false
    if farmThread then pcall(function() task.cancel(farmThread) end) end
end

-- Load settings immediately on execution
