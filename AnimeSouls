local function makeCheckbox(monName, index)
    local btn = Instance.new("TextButton", scroll)
    btn.Size = UDim2.new(1,0,0,30)
    btn.BackgroundColor3 = C.btnOff
    btn.BackgroundTransparency = 1
    btn.BorderSizePixel = 0
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 13
    btn.TextColor3 = C.textDim
    btn.TextTransparency = 1
    btn.TextXAlignment = Enum.TextXAlignment.Left

    local monLower = monName:lower()
    local sel = targetNames[monLower] == true

    if sel then
        btn.BackgroundColor3 = C.btnOn
        btn.TextColor3 = C.glow
        btn.Text = " ● " .. monName
    else
        btn.BackgroundColor3 = C.btnOff
        btn.TextColor3 = C.textDim
        btn.Text = " ○ " .. monName
    end

    btn.LayoutOrder = index or 0
    corner(8, btn)
    local btnStroke = stroke(1, C.divider, btn)
    btnStroke.Transparency = 1

    task.delay((index or 1) * 0.045, function()
        if not btn.Parent then return end
        tween(btn, 0.2, {BackgroundTransparency = 0})
        tween(btnStroke, 0.2, {Transparency = 0})
        TweenService:Create(btn, TweenInfo.new(0.2), {TextTransparency = 0}):Play()
    end)

    local btnScale = Instance.new("UIScale", btn)

    btn.MouseButton1Click:Connect(function()
        sel = not sel
        if sel then
            targetNames[monLower] = true
            tween(btn, 0.15, {BackgroundColor3 = C.btnOn})
            btn.TextColor3 = C.glow
            btn.Text = " ● " .. monName
        else
            targetNames[monLower] = nil
            tween(btn, 0.15, {BackgroundColor3 = C.btnOff})
            btn.TextColor3 = C.textDim
            btn.Text = " ○ " .. monName
        end
        saveSettings()

        TweenService:Create(btnScale, TweenInfo.new(0.08), {Scale = 0.96}):Play()
        task.delay(0.08, function()
            TweenService:Create(btnScale, TweenInfo.new(0.12, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
        end)
    end)
    checkboxes[monName] = btn
end

