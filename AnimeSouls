    end)

    local btnScale = Instance.new("UIScale", btn)

    btn.MouseButton1Click:Connect(function()
        sel = not sel
        if sel then
            targetNames[monLower] = true
            tween(btn, 0.15, {BackgroundColor3 = C.btnOn})
            btn.TextColor3 = C.glow
            btn.Text = " ● " .. monName
        else
            targetNames[monLower] = nil
            tween(btn, 0.15, {BackgroundColor3 = C.btnOff})
            btn.TextColor3 = C.textDim
            btn.Text = " ○ " .. monName
        end

