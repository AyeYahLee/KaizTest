    tostring(TARGET_PLACE_ID), typeof(TARGET_PLACE_ID)
))

-- Compare as strings on both sides — avoids relying on the obfuscated
-- build's numeric literal being byte-for-byte identical to the original.
if tostring(game.PlaceId) ~= TARGET_PLACE_ID then
    warn(string.format(
        "[Noxar Panel] Execution blocked: Incorrect Game/Place ID. Current ID: %s (expected %s)",
        tostring(game.PlaceId), TARGET_PLACE_ID
    ))
