-- Converts ANY BigNumber representation (string with suffixes like 'ai'/'ah', {mantissa, exponent}, etc.) to Lua double float
local function bigNumToNumber(val)
    if not val then return nil end
    if type(val) == "number" then
        return val
    elseif type(val) == "string" then
        local s = val:gsub("^[%,%s]+", ""):gsub("[%,%s]+$", "")
        -- If string is "1ai/1ai" or "5ah / 5ah", extract just the current (first) part before slash
        if s:find("/") then
            s = s:split("/")[1]:gsub("^[%,%s]+", ""):gsub("[%,%s]+$", "")
        end
        
        -- Handle comma-separated format "6000000,-1" -> 6000000 * 10^-1 = 600,000
        local m, e = s:match("^(%-?%d+%.?%d*)[,%s]+(%-?%d+)$")
        if m and e then
            return tonumber(m) * (10 ^ tonumber(e))
        end

        -- Handle suffix string like "1ai", "5ah", "21.6M", "600K", "300"
        local num, suffix = s:match("^(%-?%d+%.?%d*)%s*([a-zA-Z]+)$")
        if num and suffix then
            local n = tonumber(num)
            if n then
                local suf = suffix:upper()
                if suf == "K" then return n * 1e3
                elseif suf == "M" then return n * 1e6
                elseif suf == "B" then return n * 1e9
                elseif suf == "T" then return n * 1e12
                elseif suf == "QA" or suf == "QD" then return n * 1e15
                elseif suf == "QI" or suf == "QN" then return n * 1e18
                elseif suf == "SX" then return n * 1e21
                elseif suf == "SP" then return n * 1e24
                elseif suf == "OC" then return n * 1e27
                elseif suf == "NO" then return n * 1e30
                elseif suf == "DC" then return n * 1e33
                elseif suf == "UD" then return n * 1e36
                elseif suf == "DD" then return n * 1e39
                end

                -- Two-letter alphabetical suffixes (AA, AB, AC... AH, AI... ZZ)
                if #suf == 2 and suf:match("^[A-Z][A-Z]$") then
                    local c1 = suf:byte(1) - 64 -- 'A' = 1
                    local c2 = suf:byte(2) - 64
                    if c1 >= 1 and c1 <= 26 and c2 >= 1 and c2 <= 26 then
                        -- AA = index 0 (10^36), AB = index 1 (10^39)... AH = index 7 (10^57), AI = index 8 (10^60)
                        local idx = (c1 - 1) * 26 + (c2 - 1)
                        local exp = 36 + (idx * 3)
                        return n * (10 ^ math.min(exp, 305))
                    end
                elseif #suf == 3 and suf:match("^[A-Z][A-Z][A-Z]$") then
                    local c1 = suf:byte(1) - 64
                    local c2 = suf:byte(2) - 64
                    local c3 = suf:byte(3) - 64
                    if c1 >= 1 and c1 <= 26 and c2 >= 1 and c2 <= 26 and c3 >= 1 and c3 <= 26 then
                        local idx = (c1 - 1) * 676 + (c2 - 1) * 26 + (c3 - 1)
                        local exp = 36 + (26 * 26 * 3) + (idx * 3)
                        return n * (10 ^ math.min(exp, 305))
                    end
                end
                return n
            end
        end
        return tonumber(s)
    elseif type(val) == "table" or typeof(val) == "table" then
        local m = val[1] or val.Mantissa or val.mantissa or val.Base or val.base or val.m or val.Current or val.current or val.Value or val.value or val.Num or val.num
        local e = val[2] or val.Exponent or val.exponent or val.Exp or val.exp or val.e or val.Power or val.power or val.P or val.p
        if m and e then
            local numM = type(m) == "number" and m or tonumber(m) or bigNumToNumber(m)
            local numE = type(e) == "number" and e or tonumber(e)
            if numM and numE then
                return numM * (10 ^ math.min(numE, 305))
            elseif numM and type(e) == "string" then
                local powerMul = bigNumToNumber("1" .. e)
                if powerMul then return numM * powerMul end
            end
        elseif m then
            return bigNumToNumber(m)
        end
        local ok, res = pcall(function() return val:ToNumber() end)
        if ok and type(res) == "number" then return res end
        ok, res = pcall(function() return val:GetNumber() end)
        if ok and type(res) == "number" then return res end
        ok, res = pcall(function()
            local s = tostring(val)
            return tonumber(s) or bigNumToNumber(s)
        end)
        if ok and res then return res end
    end
    return nil
end

local function extractNameFromGui(gui)
    local bestName = nil
    for _, d in pairs(gui:GetDescendants()) do
        if d:IsA("TextLabel") then
            local t = d.Text
            if t and t ~= "" and t ~= "PetName" and not t:match("^Lv%.") and not t:match("^%d") and not t:match("%%") and not t:match("^x ") and not t:match("/") and not t:match("^[-+%d]") and not t:match("^[Ee]nds in") and t ~= "Boss" and t ~= "Raid Boss" and t ~= "Event" and t ~= "Mini Boss" then
                if #t >= 2 and not t:match("^[0-9%.]+[a-zA-Z]*$") then
                    bestName = t
                end
            end
        end
    end
    return bestName
end

local function getMonsterName(m, guiFolder)
    local monIdNum = tonumber(m.Name:match("%d+")) or tonumber(m:GetAttribute("MonsterId")) or tonumber(m:GetAttribute("Id"))
    
    -- 1. Query internal _G.PathTool.MgrMonsterClient directly for the exact Config.Name ("Sung Jinwoo", "Madara")
    if _G.PathTool and _G.PathTool.MgrMonsterClient and monIdNum then
        local ok, mInfo = pcall(function() return _G.PathTool.MgrMonsterClient.GetMonsterInfo(monIdNum) end)
        if ok and mInfo and mInfo.Config and mInfo.Config.Name and type(mInfo.Config.Name) == "string" and mInfo.Config.Name ~= "" then
            return mInfo.Config.Name
        end
    end

    guiFolder = guiFolder or workspace:FindFirstChild("SelfGUI")
    local attrName = m:GetAttribute("DisplayName") or m:GetAttribute("MonsterName") or m:GetAttribute("Name")
    if attrName and type(attrName) == "string" and attrName ~= "" and attrName ~= m.Name then
        return attrName
    end

    if guiFolder then
        local gui = guiFolder:FindFirstChild(m.Name)
        if not gui and monIdNum then
            gui = guiFolder:FindFirstChild("Monster_" .. tostring(monIdNum)) or guiFolder:FindFirstChild(tostring(monIdNum))
        end
        if gui then
            local name = extractNameFromGui(gui)
            if name then return name end
        end
    end

    for _, d in pairs(m:GetDescendants()) do
        if d:IsA("BillboardGui") or d:IsA("SurfaceGui") then
            local name = extractNameFromGui(d)
            if name then return name end
        end
    end

    local cleanName = m.Name:gsub("^Monster_", ""):gsub("^Client_", ""):gsub("_%d+$", "")
    if cleanName and cleanName ~= "" and not cleanName:match("^%d+$") then
        return cleanName
    end

    return nil
end

local function getHumanoid(m)
    local shower = m:FindFirstChild("Shower")
    if not shower then return nil end
    return shower:FindFirstChildOfClass("Humanoid")
end

local function getMonsterHealth(m)
    local monIdNum = tonumber(m.Name:match("%d+")) or tonumber(m:GetAttribute("MonsterId")) or tonumber(m:GetAttribute("Id"))

    -- 1. Query internal _G.PathTool API (The exact engine from your decompiled MgrMonsterClient!)
    if _G.PathTool then
        local mInfo = nil
        if _G.PathTool.MgrMonsterClient and type(_G.PathTool.MgrMonsterClient.GetMonsterInfo) == "function" and monIdNum then
            pcall(function() mInfo = _G.PathTool.MgrMonsterClient.GetMonsterInfo(monIdNum) end)
        end

        if mInfo and mInfo.HealthValue then
            if type(mInfo.IsAlive) == "function" and not mInfo:IsAlive() then
                return 0
            end

            if _G.PathTool.LogicNumber then
                local okStr, str = pcall(function()
                    local fixed = _G.PathTool.LogicNumber.FixLogicNumber(mInfo.HealthValue.Value)
                    return _G.PathTool.LogicNumber.ToString(fixed)
                end)
                if okStr and str and type(str) == "string" and str ~= "" then
                    local num = bigNumToNumber(str)
                    if num and num >= 0 then return num end
                end

                local okNum, nativeNum = pcall(function()
                    local fixed = _G.PathTool.LogicNumber.FixLogicNumber(mInfo.HealthValue.Value)
                    return _G.PathTool.LogicNumber.ToNumber(fixed)
                end)
                if okNum and type(nativeNum) == "number" and nativeNum >= 0 then
                    return nativeNum
                end
            end

            local num = bigNumToNumber(mInfo.HealthValue.Value)
            if num and num >= 0 then return num end
        end
    end

    -- 2. Check game.Workspace.Monsters server node directly
    if monIdNum then
        local monstersFolder = workspace:FindFirstChild("Monsters")
        if monstersFolder then
            local serverNode = monstersFolder:FindFirstChild("Monster_" .. tostring(monIdNum)) or monstersFolder:FindFirstChild(tostring(monIdNum))
            if serverNode then
                local healthValue = serverNode:FindFirstChild("Health")
                if healthValue and (healthValue:IsA("ValueBase") or healthValue:IsA("StringValue")) then
                    if _G.PathTool and _G.PathTool.LogicNumber then
                        local okStr, str = pcall(function()
                            local fixed = _G.PathTool.LogicNumber.FixLogicNumber(healthValue.Value)
                            return _G.PathTool.LogicNumber.ToString(fixed)
                        end)
                        if okStr and str and type(str) == "string" and str ~= "" then
                            local num = bigNumToNumber(str)
                            if num and num >= 0 then return num end
                        end
                    end
                    local num = bigNumToNumber(healthValue.Value)
                    if num and num >= 0 then return num end
                end
            end
        end
    end

    -- 3. Check MgrMonsterClient ModuleScript via require()
    local okRequire, mgr = pcall(function() return require(RS.ClientLogic.Monster.MgrMonsterClient) end)
    if okRequire and mgr and type(mgr.GetMonsterInfo) == "function" and monIdNum then
        local okRes, rec = pcall(function() return mgr.GetMonsterInfo(monIdNum) end)
        if okRes and rec and type(rec) == "table" then
            if type(rec.IsAlive) == "function" and not rec:IsAlive() then
                return 0
            end
            local rawCur = rec.HealthValue and rec.HealthValue.Value or rec.RawCurrent or rec.RawCur or rec.Current or rec.CurrentHealth or rec.CurHealth or rec.Health
            if rawCur ~= nil then
                if _G.PathTool and _G.PathTool.LogicNumber then
                    local okStr, str = pcall(function()
                        return _G.PathTool.LogicNumber.ToString(_G.PathTool.LogicNumber.FixLogicNumber(rawCur))
                    end)
                    if okStr and str and type(str) == "string" and str ~= "" then
                        local num = bigNumToNumber(str)
                        if num and num >= 0 then return num end
                    end
                end
                local num = bigNumToNumber(rawCur)
                if num and num >= 0 then return num end
            end
        end
    end

    -- 4. Check SelfGUI TextLabels (where "1ai/1ai" or "5ah/5ah" is visually displayed above the monster!)
    local guiFolder = workspace:FindFirstChild("SelfGUI")
    if guiFolder then
        local gui = guiFolder:FindFirstChild(m.Name)
        if not gui and monIdNum then
            gui = guiFolder:FindFirstChild("Monster_" .. tostring(monIdNum)) or guiFolder:FindFirstChild(tostring(monIdNum))
        end
        if gui then
            for _, d in pairs(gui:GetDescendants()) do
                if d:IsA("TextLabel") and d.Text and d.Text ~= "" then
                    local t = d.Text
                    local curStr = t:match("^(%-?%d+%.?%d*%s*[a-zA-Z]*)/%-?%d+%.?%d*%s*[a-zA-Z]*$")
                    if not curStr then
                        curStr = t:match("^(%-?%d+%.?%d*%s*[a-zA-Z]+)%s*/")
                    end
                    if curStr then
                        local num = bigNumToNumber(curStr)
                        if num and num > 0 then
                            return num
                        end
                    end
                end
            end
        end
    end

    -- 5. Fallback to Humanoid Health inside Shower folder
    local hum = getHumanoid(m)
    if hum and hum.Health > 0 then
        return hum.Health
    end

    return 0
end

local function isAlive(m)
    local monIdNum = tonumber(m.Name:match("%d+")) or tonumber(m:GetAttribute("MonsterId")) or tonumber(m:GetAttribute("Id"))
    if _G.PathTool and _G.PathTool.MgrMonsterClient and monIdNum then
        local ok, mInfo = pcall(function() return _G.PathTool.MgrMonsterClient.GetMonsterInfo(monIdNum) end)
        if ok and mInfo and type(mInfo.IsAlive) == "function" then
            return mInfo:IsAlive()
        end
    end

    local hum = getHumanoid(m)
    if hum and hum.Health <= 0 then
        return false
    end

    local health = getMonsterHealth(m)
    if health <= 0 and (hum == nil or hum.Health <= 0) then
        return false
    end

    return true
end

-- Select best target monster based on `targetMode` priority
local function getTargetMonster()
    local cm = workspace:FindFirstChild("ClientMonsters")
    if not cm then return nil end
    local guiFolder = workspace:FindFirstChild("SelfGUI")
    
    local bestMonster = nil
    local bestVal = (targetMode == "Lowest Health" or targetMode == "Nearest Distance") and math.huge or -math.huge
    local bestDist = math.huge

    for _, m in pairs(cm:GetChildren()) do
        if m:IsA("Model") then
            local name = getMonsterName(m, guiFolder)
            if name and targetNames[name:lower()] and isAlive(m) then
                local r = m:FindFirstChild("Root")
                if r and root then
                    local dist = (root.Position - r.Position).Magnitude
                    local health = getMonsterHealth(m)

                    if targetMode == "Highest Health" then
                        -- Target highest health monster first (e.g. 1ai > 5ah > 21.6M > 600K)
                        if health > bestVal + (math.max(1, math.abs(bestVal)) * 0.001) then
                            bestVal = health
                            bestDist = dist
                            bestMonster = m
                        elseif math.abs(health - bestVal) <= (math.max(1, math.abs(bestVal)) * 0.001) and dist < bestDist then
                            bestVal = health
                            bestDist = dist
                            bestMonster = m
                        end
                    elseif targetMode == "Lowest Health" then
                        -- Target lowest health monster first
                        if health < bestVal - (math.max(1, math.abs(bestVal)) * 0.001) then
                            bestVal = health
                            bestDist = dist
                            bestMonster = m
                        elseif math.abs(health - bestVal) <= (math.max(1, math.abs(bestVal)) * 0.001) and dist < bestDist then
                            bestVal = health
                            bestDist = dist
                            bestMonster = m
                        end
                    else -- "Nearest Distance"
                        if dist < bestDist then
                            bestDist = dist
                            bestVal = dist
                            bestMonster = m
                        end
                    end
                end
            end
        end
    end
    return bestMonster
end

local function tpTo(m)
    local r = m:FindFirstChild("Root")
    if r and root then
        local pos = r.CFrame.Position
        root.CFrame = CFrame.new(pos.X + 3, pos.Y, pos.Z)
    end
end

-- ── Farm loop ─────────────────────────────────────────────────────
local function farmLoop()
    local lastTarget = nil
    local lastTpTime = 0
    while farmRunning do
        local target = getTargetMonster()
        if target then
            local r = target:FindFirstChild("Root")
            local dist = (r and root) and (root.Position - r.Position).Magnitude or 0
            if target ~= lastTarget or dist > 12 or (tick() - lastTpTime) > 1.5 then
                tpTo(target)
                lastTarget = target
                lastTpTime = tick()
            end
        else
            lastTarget = nil
        end
        task.wait(0.05)
    end
end

