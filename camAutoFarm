local function equipBest()
    if not monstersEquipped then
        pcall(function() DataPullFunc:InvokeServer("PetEquipBestChannel") end)
        monstersEquipped = true
    end
end

local function unequipAll()
    if monstersEquipped then
        pcall(function() DataPullFunc:InvokeServer("PetUnEquipAllChannel") end)
        monstersEquipped = false
    end
end

