local function getIncubatorState(index)
    local eggHatchFolder = workspace:FindFirstChild("EggHatch", true)
    if not eggHatchFolder then 
        return "unknown" 
    end

    local incubator = eggHatchFolder:FindFirstChild("Hatch_" .. tostring(index))
    if not incubator then 
        return "unknown" 
    end

    local foundSomeText = false

    for _, obj in ipairs(incubator:GetDescendants()) do
        if obj:IsA("TextLabel") and obj.Text ~= "" then
            foundSomeText = true
            local text = obj.Text
            
            if string.find(text, "Select") then
                return "empty"
            elseif string.find(text, "Ready") then
                return "ready"
            elseif string.match(text, "%d+:%d+:%d+") then
                return "hatching"
            end
        end
    end
    
    if not foundSomeText then
        return "empty"
    end
    
    return "unknown"
end

local function getSecondsUntilReset()
    local t = os.date("!*t")
    local now = t.hour * 3600 + t.min * 60 + t.sec
    local diff = 86400 - now
    if diff <= 30 then diff = diff + 86400 end
    return diff
end

local function formatTime(s)
    local h = math.floor(s / 3600)
    local m = math.floor((s % 3600) / 60)
    local sec = math.floor(s % 60)
    return string.format("%02d:%02d:%02d", h, m, sec)
end

