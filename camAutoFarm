_G.NoxarBossDeathNotified = _G.NoxarBossDeathNotified or {}

function markBossDeathNotified(bossName)
    if not bossName then return end
    local deadName = (type(bossName) == "table" and bossName[1]) or tostring(bossName)
    _G.NoxarBossDeathNotified[deadName] = os.clock()

    -- Purge from bossQueue immediately so it won't queue or waste time on it
    local removedCount = 0
    if bossQueue then
        for i = #bossQueue, 1, -1 do
            if bossQueue[i] and bossQueue[i].name == deadName then
                table.remove(bossQueue, i)
                removedCount = removedCount + 1
            end
        end
    end

    -- Live UI status update
    if bossLoopEnabled and BossLoopLiveStatusLbl then
        if currentBossFight and currentBossFight.name == deadName then
            BossLoopLiveStatusLbl.Text = "Status: 💀 " .. deadName .. " died — aborting..."
            BossLoopLiveStatusLbl.TextColor3 = C.red
        elseif removedCount > 0 then
            BossLoopLiveStatusLbl.Text = "Status: 💀 " .. deadName .. " died — removed from queue (" .. #bossQueue .. " left)"
            BossLoopLiveStatusLbl.TextColor3 = C.red
        end
    end
end

function wasBossDeathNotified(bossName, sinceTime)
    local t = bossName and _G.NoxarBossDeathNotified and _G.NoxarBossDeathNotified[bossName]
    return t ~= nil and (not sinceTime or t >= sinceTime)
end

function resnapToCurrentBoss(bossName, fallbackMonster)
    local monster = findBossByName(bossName) or fallbackMonster
    if not monster then return fallbackMonster end
    local root = monster:FindFirstChild("Root") or monster.PrimaryPart
    if root then
        _G.NoxarSetBossMount(true)
        task.wait(0.1)
        glueToTarget(root)
        task.wait(0.1)
        _G.NoxarSetBossMount(false)
    end
    return monster
end

-- Fights a specific boss instance until it dies. Teleports onto it once
-- (same one-shot style as the saved-farm-spot TP button) and then just
-- watches for it to disappear from ClientMonsters -- damage is expected
-- to come from your in-game auto-attack (e.g. equipped pets), not from
-- this script clicking anything. "Still present in ClientMonsters" is
-- the same death check used everywhere else in this file. Bails out
-- early (returns false) if bossLoopEnabled goes false mid-fight.
function fightBossUntilDead(monster, isSpecial, bossName)
    local root = monster:FindFirstChild("Root") or monster.PrimaryPart
    if not root then
        local startRootWait = os.clock()
        while os.clock() - startRootWait < 2 do
            root = monster:FindFirstChild("Root") or monster.PrimaryPart
            if root then break end
            task.wait(0.1)
        end
    end

    local fightStartedAt = os.clock()
    local lastSnapAt = fightStartedAt

    if root then
        BossLoopLiveStatusLbl.Text = "Status: Snapping onto " .. tostring(bossName or "boss") .. "..."
        BossLoopLiveStatusLbl.TextColor3 = C.gold

        _G.NoxarSetBossMount(true)
        task.wait(0.1)
        glueToTarget(root)
        task.wait(0.1)
        _G.NoxarSetBossMount(false)
    end

    BossLoopLiveStatusLbl.Text = "Status: Fighting " .. tostring(bossName or "boss") .. "..."
    BossLoopLiveStatusLbl.TextColor3 = C.gold

    while bossLoopEnabled do
        if wasBossDeathNotified(bossName, fightStartedAt) then
            return true -- server kill notification confirmed it
        end

        if not clientMonsters:FindFirstChild(monster.Name) then
            return true -- boss is dead/disappeared from ClientMonsters
        end

        -- Teleport/glitch failsafe: if we have been "fighting" the same target
        -- for 5s with no MonsterDead notification, snap directly back onto the
        -- live boss model again. This does NOT area-teleport, only direct snap.
        if os.clock() - lastSnapAt >= 5 then
            BossLoopLiveStatusLbl.Text = "Status: Re-snapping to " .. tostring(bossName or "boss") .. "..."
            monster = resnapToCurrentBoss(bossName, monster) or monster
            lastSnapAt = os.clock()
        end

        if isSpecial and os.clock() - fightStartedAt >= 9 then
            BossLoopLiveStatusLbl.Text = "Status: " .. tostring(bossName or "Special") .. " timed out after 9s — continuing..."
            return true -- special/ultra timeout guard so the loop never gets stuck here
        end

        task.wait(0.5) -- just polling for death now, no need to run at ATTACK_DELAY speed
    end

    return false -- got turned off mid-fight
end

-- Runs the full cycle for one queued boss: travel to its area, scan for
-- it by name, teleport onto it, fight until dead.
function runBossFight(entry)
    currentBossFight = entry

    -- Check if this boss was already killed while waiting in the queue
    if wasBossDeathNotified(entry.name) then
        BossLoopLiveStatusLbl.Text = "Status: 💀 " .. entry.name .. " was killed — skipping!"
        BossLoopLiveStatusLbl.TextColor3 = C.red
        task.wait(1)
        currentBossFight = nil
        return
    end

    _G.NoxarSetBossMount(true) -- mount while traveling between boss/special areas
    BossLoopLiveStatusLbl.Text = "Status: " .. entry.name .. " @ " .. entry.area .. " — traveling..."
    BossLoopLiveStatusLbl.TextColor3 = C.gold

    local areaId = AreaFarmIDs[entry.area]
    if not areaId then
        BossLoopLiveStatusLbl.Text = "Status: ❌ Unknown area for " .. entry.name .. " (" .. entry.area .. ")"
        BossLoopLiveStatusLbl.TextColor3 = C.red
        currentBossFight = nil
        return
    end

    pcall(function()
        DataPullFunc:InvokeServer("AreaTeleportToRegionChannel", areaId)
    end)
    task.wait(2)
    if not bossLoopEnabled then currentBossFight = nil; return end

    if wasBossDeathNotified(entry.name) then
        BossLoopLiveStatusLbl.Text = "Status: 💀 " .. entry.name .. " killed during travel — skipping!"
        BossLoopLiveStatusLbl.TextColor3 = C.red
        task.wait(1)
        currentBossFight = nil
        return
    end

    BossLoopLiveStatusLbl.Text = "Status: Waiting for monsters to load in " .. entry.area .. "..."
    local settled, died = waitForMonstersToSettle(6, entry.name)
    if not bossLoopEnabled or died or wasBossDeathNotified(entry.name) then
        if died or wasBossDeathNotified(entry.name) then
            BossLoopLiveStatusLbl.Text = "Status: 💀 " .. entry.name .. " killed while loading — skipping!"
            BossLoopLiveStatusLbl.TextColor3 = C.red
            task.wait(1)
        end
        currentBossFight = nil
        return
    end

    BossLoopLiveStatusLbl.Text = "Status: Searching for " .. entry.name .. "..."
    local monster = nil
    local searchStartedAt = os.clock()
    local maxFindWait = 15

    while bossLoopEnabled and os.clock() - searchStartedAt < maxFindWait do
        if wasBossDeathNotified(entry.name) then
            BossLoopLiveStatusLbl.Text = "Status: 💀 " .. entry.name .. " killed while searching — skipping!"
            BossLoopLiveStatusLbl.TextColor3 = C.red
            task.wait(1)
            currentBossFight = nil
            return
        end

        monster = findBossByName(entry.name)
        if monster then
            break -- found early, do not wait the rest of the timeout
        end

        local remaining = math.max(0, maxFindWait - (os.clock() - searchStartedAt))
        BossLoopLiveStatusLbl.Text = "Status: Searching for " .. entry.name .. "... " .. string.format("%.0f", remaining) .. "s"
        task.wait(0.25)
    end

    if not bossLoopEnabled then currentBossFight = nil; return end

    if wasBossDeathNotified(entry.name) then
        BossLoopLiveStatusLbl.Text = "Status: 💀 " .. entry.name .. " killed — skipping!"
        BossLoopLiveStatusLbl.TextColor3 = C.red
        task.wait(1)
        currentBossFight = nil
        return
    end

    if not monster then
        BossLoopLiveStatusLbl.Text = "Status: ❌ " .. entry.name .. " not found after 15s search"
        BossLoopLiveStatusLbl.TextColor3 = C.red
        currentBossFight = nil
        return
    end

    local isSpecial = isSpecialBossName(entry.name)
    BossLoopLiveStatusLbl.Text = "Status: Fighting " .. entry.name .. "..."
    BossLoopLiveStatusLbl.TextColor3 = C.gold
    local won = fightBossUntilDead(monster, isSpecial, entry.name)

    if won then
        _G.NoxarSetBossMount(true) -- remount after kill so next travel/return is mounted
        BossLoopLiveStatusLbl.Text = "Status: " .. entry.name .. " defeated! Waiting 2s..."
        task.wait(2)
    end

    currentBossFight = nil
end

function isAlreadyTracked(bossName)
    if currentBossFight and currentBossFight.name == bossName then return true end
    for _, q in ipairs(bossQueue) do
        if q.name == bossName then return true end
    end
    return false
end

connectTracked("notificationEvent", NotificationEvent.OnClientEvent, function(...)
    local args = table.pack(...) -- table.pack, not ipairs -- some slots are nil and ipairs would silently stop early

    -- Death notifications use ServerMessage/MonsterDead and include the dead
    -- monster name at args[4][1]. Track them so active fights can end instantly.
    if args[1] == "ServerMessage" and args[2] == "MonsterDead" then
        local payload = args[4]
        if type(payload) == "table" then
            markBossDeathNotified(payload[1])
        end
        return
    end

    if not bossLoopEnabled then return end
    if args[1] ~= "ViewBubble" then return end

    -- Regular bosses use "MonsterAppear"; Ultra Rare monsters use
    -- "UltraRareMonsterAppear". Both payload shapes include Name and
    -- DescParams[2] = area name, so the same queue/fight path can handle both.
    local eventKind = args[2]
    if eventKind ~= "MonsterAppear" and eventKind ~= "UltraRareMonsterAppear" then return end

    local payload = args[4]
    if type(payload) ~= "table" then return end

    local bossName = payload.Name
    local areaName = payload.DescParams and payload.DescParams[2]
    if not bossName or not areaName then return end

    -- Clear stale death notification on a fresh spawn so future fights can queue properly
    if _G.NoxarBossDeathNotified then
        _G.NoxarBossDeathNotified[bossName] = nil
    end

    if not selectedBosses[bossName] then return end -- not one you've opted in to
    if isAlreadyTracked(bossName) then return end

    table.insert(bossQueue, { name = bossName, area = areaName })
    if not currentBossFight then
        BossLoopLiveStatusLbl.Text = "Status: " .. bossName .. " spawned @ " .. areaName .. " — queued (" .. #bossQueue .. ")"
    else
        BossLoopLiveStatusLbl.Text = "Status: Fighting " .. currentBossFight.name .. " — " .. bossName .. " queued next (" .. #bossQueue .. ")"
    end
end)

-- Dispatcher: whenever nothing's currently being fought and the queue has
-- something waiting, pop the next one (FIFO) and run it -- never
-- interrupting whatever fight is already in progress. When the queue
-- drains completely, return to the farming spot and cleanly resume the
-- regular Auto-Farm loop if it was on before the boss loop took over.
spawnTracked("bossLoop", function()
    local returnedToFarmSpot = true -- starts true so it doesn't try to "return" before ever leaving
    while task.wait(0.5) do
        if not bossLoopEnabled then
            returnedToFarmSpot = true
            continue
        end

        if not currentBossFight and #bossQueue > 0 then
            returnedToFarmSpot = false
            if running then
                wasFarmingBeforeBossFight = true
                toggleFarming(false) -- cleanly stop Auto-Farm (updates its button too), not just flipping `running`
            else
                wasFarmingBeforeBossFight = false
            end

            local nextEntry = table.remove(bossQueue, 1)
            runBossFight(nextEntry)

        elseif not currentBossFight and #bossQueue == 0 and not returnedToFarmSpot then
            if farmingSpot then
                BossLoopLiveStatusLbl.Text = "Status: Queue empty — returning to Farming Spot..."
                BossLoopLiveStatusLbl.TextColor3 = Color3.fromRGB(205, 215, 245)
                -- Teleport/travel back to saved Farming Spot (stays mounted during travel)
                teleportToAreaFarmSpot(farmingSpot, true, 5)
            end
            _G.NoxarSetBossMount(false, true) -- Unmount AFTER travel/teleport back to Farming Spot completes
            if wasFarmingBeforeBossFight then
                toggleFarming(true) -- cleanly restart Auto-Farm (spawns a fresh farmLoop thread, updates its button)
                wasFarmingBeforeBossFight = false
            end
            BossLoopLiveStatusLbl.Text = "Status: Waiting for a boss spawn..."
            BossLoopLiveStatusLbl.TextColor3 = Color3.fromRGB(205, 215, 245)
            returnedToFarmSpot = true
        end
    end
end)


-- ==========================================
-- 7.7 AUTO RIFT (logic)
-- ==========================================
-- Scans workspace.DynamicDungeon for a rift portal, teleports to it,
-- clicks it, creates a team, starts the dungeon, waits until the player is
-- inside the arena, then performs the same mount -> snap -> unmount action
-- used by BossLoop. Monster lookup is strictly gated by the Rift arena
-- state, so ClientMonsters outside the arena are never used as targets.
-- After the boss dies (or the arena disappears), the arena state is cleared
-- before leaving and no monster scan is performed until the next entry.

riftRunning = riftRunning or false
riftDelayBeforeLeave = riftDelayBeforeLeave or 1 -- seconds to wait after boss dies before firing ArenaLeaveChannel
enteredRifts = enteredRifts or {} -- [dungeonInstance] = true, so we never re-click a rift we already entered
riftKillCount = riftKillCount or 0

autoHealEnabled = autoHealEnabled or false
autoHealThreshold = math.max(1, math.floor(tonumber(autoHealThreshold) or 1))
-- Captured when a Rift run starts; compared only after that Rift is over.
riftPetCountAtStart = nil
-- Mutex/queue gate: no Rift search may start while Auto Heal is active.
riftHealingInProgress = false
riftRiftSearchPausedUntil = 0
riftPostRiftTransition = false
-- Strict Auto Rift state machine. Only SEARCHING may call findRift().
riftPhase = "IDLE"
-- Incrementing this invalidates every older Auto Rift loop instance.
_G.NoxarRiftLoopGeneration = (_G.NoxarRiftLoopGeneration or 0) + 1

-- Remove markers left by the temporary healing-pad diagnostic tool.
do
    local oldRiftHealDebug = workspace:FindFirstChild("NoxarRiftHealDebug")
    if oldRiftHealDebug then oldRiftHealDebug:Destroy() end
    -- Clear the temporary diagnostic globals left by the previous version.
    clearRiftHealingDebugMarkers = nil
    scanRiftHealingCandidates = nil
    riftHealingDebugFolder = nil
end

-- Per-entry Rift state. This is deliberately reset for every new arena so
-- the mount/snap/unmount sequence runs once per arena, not once per monster.
riftArenaActive = false
riftArenaEntryId = 0
riftArenaPortalPosition = nil
riftArenaBossBarSeen = false
riftArenaSnapDone = false
riftArenaMonster = nil

-- Exact PlayerGui paths for the top Boss Health Bar. The bar is also a
-- useful fallback arena-status signal on games/builds that do not expose an
-- explicit InArena/ArenaStatus attribute.
function getRiftBossBarState()
    local pg = LP:FindFirstChild("PlayerGui")
    local mainGui = pg and pg:FindFirstChild("MainGui")
    local screenGui = mainGui and mainGui:FindFirstChild("ScreenGui")
    local mainTopView = screenGui and screenGui:FindFirstChild("MainTopView")
    local bgBoss = mainTopView and mainTopView:FindFirstChild("BgBoss")

    if bgBoss and bgBoss.Visible then
        local hpBar = bgBoss:FindFirstChild("HpBar")
        local labValue = hpBar and hpBar:FindFirstChild("LabValue")
        if labValue and labValue.Text and labValue.Text ~= "" then
            local curHpStr = labValue.Text:match("^([%d%.]+)")
            if curHpStr and tonumber(curHpStr) and tonumber(curHpStr) <= 0 then
                return false, true -- dead, but the boss bar still exists
            end
        end
        return true, true -- alive/unknown HP, visible boss bar
    end
    return false, false -- no visible boss bar
end

-- Keeps the existing BossLoop-facing function name/behavior intact.
function isRiftBossAlive()
    local alive = getRiftBossBarState()
    return alive
end

-- The boss name is optional. When the UI exposes it, use it to choose the
-- exact ClientMonsters model; otherwise the single/nearest Rift candidate is
-- used below.
function getRiftBossBarName()
    local pg = LP:FindFirstChild("PlayerGui")
    local mainGui = pg and pg:FindFirstChild("MainGui")
    local screenGui = mainGui and mainGui:FindFirstChild("ScreenGui")
    local mainTopView = screenGui and screenGui:FindFirstChild("MainTopView")
    local bgBoss = mainTopView and mainTopView:FindFirstChild("BgBoss")
    if not bgBoss then return nil end

    for _, labelName in ipairs({"LabName", "BossName", "LabTitle", "Title"}) do
        local label = bgBoss:FindFirstChild(labelName, true)
        if label and label:IsA("TextLabel") and label.Text and label.Text ~= "" then
            return label.Text
        end
    end
    return nil
end

-- Read a boolean-like arena value from an Attribute/ValueObject/TextLabel.
-- The game has used slightly different names for this status in different
-- builds, so the reader intentionally accepts the common variants while
-- still returning nil when no status signal exists.
function parseRiftArenaStatus(value)
    if type(value) == "boolean" then return value end
    if type(value) == "number" then return value ~= 0 end
    if type(value) ~= "string" then return nil end

    local text = value:lower():gsub("^%s+", ""):gsub("%s+$", "")
    if text == "true" or text == "1" or text == "active" or text == "inside"
        or text == "in" or text == "entered" or text == "running" or text == "started" then
        return true
    end
    if text == "false" or text == "0" or text == "inactive" or text == "outside"
        or text == "out" or text == "left" or text == "none" or text == "idle"
        or text == "closed" or text == "ended" or text == "finished" then
        return false
    end
    return nil
end

function readRiftArenaStatusFromObject(object, statusNames)
    if not object then return nil end

    for _, name in ipairs(statusNames) do
        local attribute = object:GetAttribute(name)
        local parsedAttribute = parseRiftArenaStatus(attribute)
        if parsedAttribute ~= nil then
            return parsedAttribute
        end

        local valueObject = object:FindFirstChild(name, true)
        if valueObject then
            local value = nil
            if valueObject:IsA("ValueBase") then
                value = valueObject.Value
            elseif valueObject:IsA("TextLabel") or valueObject:IsA("TextButton") then
                value = valueObject.Text
            else
                value = valueObject:GetAttribute("Value")
                if value == nil then value = valueObject:GetAttribute("Status") end
            end
            local parsedValue = parseRiftArenaStatus(value)
            if parsedValue ~= nil then
                return parsedValue
            end
        end
    end
    return nil
end

-- Prefer a real game status if it exists. The boss bar is intentionally not
-- used here; it is only the fallback handled by isRiftArenaActive(), because
-- the bar can take a moment to appear after the arena has loaded.
function getRiftArenaStatusSignal()
    local statusNames = {
        "InRiftArena", "IsInRiftArena", "RiftArenaActive", "RiftArenaStatus",
        "InArena", "IsInArena", "ArenaActive", "ArenaStatus", "DungeonStatus"
    }

    local containers = {LP, LP.Character, workspace}
    local pg = LP:FindFirstChild("PlayerGui")
    if pg then
        table.insert(containers, pg)
        local mainGui = pg:FindFirstChild("MainGui")
        if mainGui then table.insert(containers, mainGui) end
    end

    for _, object in ipairs(containers) do
        local status = readRiftArenaStatusFromObject(object, statusNames)
        if status ~= nil then return status end
    end
    return nil
end

function deactivateRiftArena()
    riftArenaActive = false
    riftArenaBossBarSeen = false
    riftArenaMonster = nil
    riftArenaPortalPosition = nil
end

-- Single gate for every Rift monster search. A real false arena status or
-- disappearance of the boss bar closes the gate immediately. Otherwise we
-- use the active per-entry state, any real arena status, and entry distance
-- as fallbacks.
function isRiftArenaActive()
    if not riftArenaActive then return false end

    local explicitStatus = getRiftArenaStatusSignal()
    if explicitStatus == false then
        deactivateRiftArena()
        return false
    end

    local _, bossBarVisible = getRiftBossBarState()
    if bossBarVisible then
        riftArenaBossBarSeen = true
        return true
    end

    -- Once the boss bar has existed, its disappearance means the arena has
    -- ended/disappeared. This check intentionally comes before an explicit
    -- `true` status because the bar disappearing is the strongest end-of-
    -- arena signal and prevents any stale status from causing more scans.
    if riftArenaBossBarSeen then
        deactivateRiftArena()
        return false
    end

    -- Before the bar appears, make sure the character is still away from the
    -- portal/overworld position where entry was initiated. This check also
    -- protects against a stale `ArenaStatus = true` after a forced exit.
    local root = getRoot()
    if not root or not riftArenaPortalPosition
        or (root.Position - riftArenaPortalPosition).Magnitude <= 50 then
        deactivateRiftArena()
        return false
    end

    if explicitStatus ~= nil then
        return explicitStatus
    end

    return true
end

-- Finds an active, not-yet-entered rift portal in workspace.DynamicDungeon.
-- Returns {instance, dungeonId, startTick, clickPart} or nil.
function findRift()
    -- Never scan/queue a new portal outside the SEARCHING phase.
    if riftPhase ~= "SEARCHING" then return nil end
    if riftHealingInProgress or riftPostRiftTransition then return nil end

    local dd = workspace:FindFirstChild("DynamicDungeon")
    if not dd then return nil end

    for _, dungeon in ipairs(dd:GetChildren()) do
        if enteredRifts[dungeon] then continue end
        local dungeonId = tonumber(dungeon.Name:match("Dungeon_(%d+)"))
        local startTick = dungeon:GetAttribute("DungeonStartTick")
        if dungeonId and startTick then
            local clickPart = nil
            for _, d in ipairs(dungeon:GetDescendants()) do
                if d:IsA("ClickDetector") and d.Parent:IsA("BasePart") then
                    clickPart = d.Parent
                    break
                end
            end
            if not clickPart then
                for _, d in ipairs(dungeon:GetDescendants()) do
                    if d:IsA("BasePart") then
                        clickPart = d
                        break
                    end
                end
            end
            if clickPart then
                return {
                    instance = dungeon,
                    dungeonId = dungeonId,
                    startTick = startTick,
                    clickPart = clickPart,
                }
            end
        end
    end
    return nil
end

function riftTeleportTo(part)
    local root = getRoot()
    if root and part then
        local pos = part.Position
        root.CFrame = CFrame.new(pos.X, pos.Y, pos.Z)
    end
end

function riftClickPart(part)
    local cd = part:FindFirstChildOfClass("ClickDetector")
    if cd then
        pcall(function() fireclickdetector(cd) end)
        return true
    end
    return false
end

function riftCreateTeam(dungeonId, startTick)
    return pcall(function()
        DataPullFunc:InvokeServer("DungeonCreateTeamChannel", dungeonId, startTick)
    end)
end

function riftStartDungeon(dungeonId, startTick)
    return pcall(function()
        DataPullFunc:InvokeServer("DungeonStartChannel", dungeonId, startTick)
    end)
end

function riftLeaveArena()
    return pcall(function()
        DataPullFunc:InvokeServer("ArenaLeaveChannel")
    end)
end

function isCurrentRiftLoop(generation)
    return riftRunning and generation ~= nil
        and generation == _G.NoxarRiftLoopGeneration
end

function setRiftPhase(phase, generation)
    if generation == nil or generation == _G.NoxarRiftLoopGeneration then
        riftPhase = phase
    end
end

function startRiftLoop()
    _G.NoxarRiftLoopGeneration = (_G.NoxarRiftLoopGeneration or 0) + 1
    local generation = _G.NoxarRiftLoopGeneration
    riftPhase = "SEARCHING"
    riftPostRiftTransition = false
    spawnTracked("riftLoop", function()
        riftLoop(generation)
    end)
end

function stopRiftLoop()
    _G.NoxarRiftLoopGeneration = (_G.NoxarRiftLoopGeneration or 0) + 1
    riftPhase = "IDLE"
    riftPostRiftTransition = false
    riftHealingInProgress = false
    riftRiftSearchPausedUntil = 0
    cancelTracked("riftLoop")
end

-- SelfGUI contains only this player's pet health-bar objects. ClientPets
-- includes pets belonging to other players, so it must not be used for the
-- Auto Heal baseline/count.
function getActiveRiftPetCount()
    local selfGui = workspace:FindFirstChild("SelfGUI")
    if not selfGui then return 0 end

    local count = 0
    for _, object in ipairs(selfGui:GetDescendants()) do
        if object.Name == "HpBarGui" then
            count += 1
        end
    end
    return count
end

function getRiftInstancePosition(instance)
    if not instance then return nil end
    if instance:IsA("BasePart") then
        return instance.Position
    end

    if instance:IsA("Model") then
        local ok, pivot = pcall(function() return instance:GetPivot() end)
        if ok and pivot then return pivot.Position end
        if instance.PrimaryPart then return instance.PrimaryPart.Position end
    end

    for _, descendant in ipairs(instance:GetDescendants()) do
        if descendant:IsA("BasePart") then
            return descendant.Position
        end
    end
    return nil
end

-- Exact healing trigger identified from the workspace inspection:
-- Workspace.Area.center.ServerZone.Recover.ec_1
function findRiftHealingPad()
    local area = workspace:FindFirstChild("Area")
    local center = area and area:FindFirstChild("center")
    local serverZone = center and center:FindFirstChild("ServerZone")
    local recover = serverZone and serverZone:FindFirstChild("Recover")
    local exactPad = recover and recover:FindFirstChild("ec_1")

    if exactPad and getRiftInstancePosition(exactPad) then
        return exactPad
    end

    -- Small fallbacks for streaming/renames, while keeping ec_1 as the
    -- primary target discovered from the live workspace dump.
    local fallback = recover and (recover:FindFirstChild("Rec_1") or recover)
    if fallback and getRiftInstancePosition(fallback) then
        return fallback
    end

    local namedPad = workspace:FindFirstChild("ec_1", true)
        or workspace:FindFirstChild("Rec_1", true)
        or workspace:FindFirstChild("HealingPad", true)
    if namedPad and getRiftInstancePosition(namedPad) then
        return namedPad
    end

    return nil
end

function maybeAutoHealAfterRift(generation)
    if generation and not isCurrentRiftLoop(generation) then
        return false
    end

    -- If another Rift loop instance reached this point, wait for the first
    -- one to finish healing instead of starting another search/teleport.
    if riftHealingInProgress then
        while riftHealingInProgress and riftRunning do
            task.wait(0.1)
        end
        return true
    end

    -- Acquire the gate before any waits. This prevents a second loop from
    -- finding the next DynamicDungeon while this run is checking the pets.
    riftHealingInProgress = true

    local originalCount = riftPetCountAtStart
    riftPetCountAtStart = nil

    if not autoHealEnabled or not originalCount or originalCount <= 0 then
        riftHealingInProgress = false
        return false
    end

    -- Give ArenaLeaveChannel a moment to finish moving the player back to
    -- the normal map before reading the pet folder and teleporting to Recover.
    task.wait(0.5)
    if generation and not isCurrentRiftLoop(generation) then
        riftHealingInProgress = false
        return false
    end
    local currentCount = getActiveRiftPetCount()
    local deadCount = math.max(0, originalCount - currentCount)
    local threshold = math.max(1, math.floor(tonumber(autoHealThreshold) or 1))
    if deadCount < threshold then
        riftHealingInProgress = false
        return false
    end

    local healingPad, healingPosition
    for attempt = 1, 10 do
        healingPad = findRiftHealingPad()
        healingPosition = getRiftInstancePosition(healingPad)
        if healingPosition then break end
        task.wait(0.2)
    end

    local root = getRoot()
    if not healingPosition or not root then
        RiftStatusLbl.Text = "\xe2\x9a\xa0 Auto Heal: healing pad not found"
        RiftStatusLbl.TextColor3 = C.red
        riftHealingInProgress = false
        return false
    end
    if generation and not isCurrentRiftLoop(generation) then
        riftHealingInProgress = false
        return false
    end

    setRiftPhase("HEALING", generation)
    RiftStatusLbl.Text = "\xf0\x9f\x92\x9a Auto Heal: " .. deadCount .. " pet(s) down \xe2\x80\x94 teleporting..."
    RiftStatusLbl.TextColor3 = C.gold
    root.CFrame = CFrame.new(healingPosition.X, healingPosition.Y + 3, healingPosition.Z)
    root.AssemblyLinearVelocity = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero

    RiftStatusLbl.Text = "\xf0\x9f\x92\x9a Auto Heal: healing pets for 4 seconds..."
    RiftStatusLbl.TextColor3 = C.green
    task.wait(4)
    if generation and not isCurrentRiftLoop(generation) then
        riftHealingInProgress = false
        return false
    end

    -- Keep the search gate closed for one short scheduling tick after the
    -- four-second heal, then release it so the normal loop can queue the next
    -- Rift in an orderly way.
    riftRiftSearchPausedUntil = os.clock() + 0.1
    riftHealingInProgress = false
    return true
end

-- Every call to this function is made only after isRiftArenaActive() has
-- passed. It never searches ClientMonsters while outside the arena.
function findRiftMonster()
    if not isRiftArenaActive() then return nil end

    buildNameCache()
    local bossBarName = getRiftBossBarName()
    local bossBarNameLower = bossBarName and bossBarName:lower() or nil
    local candidates = {}
    local preferred = {}
    local playerRoot = getRoot()

    for _, monster in ipairs(clientMonsters:GetChildren()) do
        local root = monster:FindFirstChild("Root")
        if not root or not root:IsA("BasePart") then
            root = monster.PrimaryPart
        end

        if root and root:IsA("BasePart") then
            local info = nameCache[monster.Name]
            local displayName = info and info.name or monster.Name
            local displayLower = displayName:lower()
            local modelLower = monster.Name:lower()
            local candidate = {
                model = monster,
                root = root,
                displayName = displayName,
            }
            table.insert(candidates, candidate)

            -- The Rift boss bar is the most reliable exact target when its
            -- name is available.
            if bossBarNameLower and (displayLower == bossBarNameLower
                or displayLower:find(bossBarNameLower, 1, true)
                or bossBarNameLower:find(displayLower, 1, true)) then
                table.insert(preferred, candidate)
            elseif displayLower:find("rift", 1, true)
                or modelLower:find("rift", 1, true)
                or displayLower:find("boss", 1, true) then
                table.insert(preferred, candidate)
            end
        end
    end

    if #preferred > 0 then
        return preferred[1].model
    end
    if #candidates == 1 then
        return candidates[1].model
    end
    if #candidates == 0 then return nil end

    -- If the arena streams more than one model and the nameplate is not
    -- available yet, use the closest one. This is still protected by the
    -- arena gate above, so overworld monsters are never considered.
    if playerRoot then
        table.sort(candidates, function(a, b)
            return (a.root.Position - playerRoot.Position).Magnitude
                < (b.root.Position - playerRoot.Position).Magnitude
        end)
    end
    return candidates[1].model
end

function waitForRiftMonster(maxWait, generation)
    local start = os.clock()
    while isCurrentRiftLoop(generation) and os.clock() - start < maxWait do
        if not isRiftArenaActive() then return nil end
        local monster = findRiftMonster()
        if monster then return monster end
        task.wait(0.15)
    end
    return nil
end

-- Exact BossLoop sequence requested for Auto Rift:
--   mount -> wait .3 -> snap to the Rift monster -> wait .5 -> unmount.
-- Uses the existing BossLoop mount helper and glueToTarget; no second mount
-- implementation is created here.
function mountSnapUnmountRiftMonster(monster)
    if not monster or not isRiftArenaActive() then return false end

    local root = monster:FindFirstChild("Root") or monster.PrimaryPart
    if not root then return false end

    _G.NoxarSetBossMount(true)
    task.wait(0.4)

    local snapped = false
    if isRiftArenaActive() and monster.Parent and root.Parent then
        pcall(function()
            glueToTarget(root)
            snapped = true
        end)
    end

    task.wait(0.5)
    _G.NoxarSetBossMount(false)
    return snapped
end

-- Main loop. Tracked via spawnTracked("riftLoop", ...) so re-toggling
-- the feature off/on never stacks duplicate loops, and CloseBtn's
-- cancelAllTrackedThreads() cleans this up along with everything else.
function riftLoop(myGeneration)
    while isCurrentRiftLoop(myGeneration) do
        -- Only SEARCHING may reach the portal scan. All other phases are
        -- serialized and wait here until the owner advances the state.
        if riftPhase ~= "SEARCHING"
            or riftHealingInProgress
            or riftPostRiftTransition then
            task.wait(0.1)
            continue
        end

        local searchWait = (riftRiftSearchPausedUntil or 0) - os.clock()
        if searchWait > 0 then
            task.wait(math.min(0.1, searchWait))
            continue
        end

        for inst in pairs(enteredRifts) do
            if not inst.Parent then enteredRifts[inst] = nil end
        end

        -- We are outside any Rift arena while looking for a new portal.
        deactivateRiftArena()
        RiftStatusLbl.Text = "\xf0\x9f\x94\x8d Scanning for active rift portal..."
        RiftStatusLbl.TextColor3 = C.sub
        local rift = findRift()

        if not rift then
            task.wait(1)
            continue
        end

        if not isCurrentRiftLoop(myGeneration) then break end

        setRiftPhase("ENTERING", myGeneration)
        RiftStatusLbl.Text = "\xf0\x9f\x93\x8d Found rift (" .. rift.instance.Name .. ") \xe2\x80\x94 teleporting..."
        riftTeleportTo(rift.clickPart)
        task.wait(0.3)

        local root = getRoot()
        if root and rift.clickPart then
            local dist = (root.Position - rift.clickPart.Position).Magnitude
            if dist > 12 then
                riftTeleportTo(rift.clickPart)
                task.wait(0.2)
            end
        end

        RiftStatusLbl.Text = "\xf0\x9f\x91\x86 Opening rift menu..."
        riftClickPart(rift.clickPart)
        enteredRifts[rift.instance] = true
        task.wait(0.5)

        root = getRoot()
        if root and rift.clickPart then
            local dist = (root.Position - rift.clickPart.Position).Magnitude
            if dist > 12 then
                riftTeleportTo(rift.clickPart)
                task.wait(0.2)
            end
        end

        RiftStatusLbl.Text = "\xf0\x9f\x91\xa5 Creating team..."
        local ok1 = riftCreateTeam(rift.dungeonId, rift.startTick)
        task.wait(0.3)

        if not isCurrentRiftLoop(myGeneration) then break end

        RiftStatusLbl.Text = "\xe2\x96\xb6 Entering rift arena..."
        -- Snapshot immediately before the server starts this Rift. The
        -- baseline is not checked again until the Rift has fully ended.
        riftPetCountAtStart = getActiveRiftPetCount()
        local ok2 = riftStartDungeon(rift.dungeonId, rift.startTick)
        task.wait(0.5)

        if not ok1 or not ok2 then
            RiftStatusLbl.Text = "\xe2\x9a\xa0 Enter failed \xe2\x80\x94 retrying in 3s"
            RiftStatusLbl.TextColor3 = C.red
            enteredRifts[rift.instance] = nil
            deactivateRiftArena()
            task.wait(3)
            setRiftPhase("SEARCHING", myGeneration)
            continue
        end

        RiftStatusLbl.Text = "\xe2\x8f\xb3 Loading arena & verifying entry..."
        local portalPos = rift.clickPart.Position
        local enteredArena = false
        local verifyStart = os.clock()

        while isCurrentRiftLoop(myGeneration) and os.clock() - verifyStart < 6 do
            root = getRoot()
            local currentDist = root and (root.Position - portalPos).Magnitude or 0
            if currentDist > 50 then
                enteredArena = true
                break
            end
            task.wait(0.25)
        end

        if not enteredArena then
            RiftStatusLbl.Text = "\xe2\x9a\xa0 Failed to enter arena \xe2\x80\x94 resetting portal..."
            RiftStatusLbl.TextColor3 = C.red
            enteredRifts[rift.instance] = nil
            deactivateRiftArena()
            task.wait(2)
            setRiftPhase("SEARCHING", myGeneration)
            continue
        end

        if not isCurrentRiftLoop(myGeneration) then break end

        -- This is the per-arena entry edge. From here on, all monster
        -- searches are gated by isRiftArenaActive().
        riftArenaEntryId += 1
        riftArenaActive = true
        riftArenaPortalPosition = portalPos
        riftArenaBossBarSeen = false
        riftArenaSnapDone = false
        riftArenaMonster = nil
        setRiftPhase("FIGHTING", myGeneration)

        RiftStatusLbl.Text = "\xf0\x9f\x94\x8d Inside Rift arena \xe2\x80\x94 searching for monster..."
        RiftStatusLbl.TextColor3 = C.gold
        local monster = waitForRiftMonster(12, myGeneration)

        -- If the arena ended while the target was loading, do not scan again
        -- and do not attempt a teleport outside the arena.
        if not isCurrentRiftLoop(myGeneration) then break end
        if not isRiftArenaActive() then
            RiftStatusLbl.Text = "\xe2\x9a\xa0 Rift arena ended before target load"
            RiftStatusLbl.TextColor3 = C.red
            setRiftPhase("LEAVING", myGeneration)
            riftPostRiftTransition = true
            deactivateRiftArena()
            riftLeaveArena()
            setRiftPhase("CHECKING_PETS", myGeneration)
            maybeAutoHealAfterRift(myGeneration)
            if not isCurrentRiftLoop(myGeneration) then break end
            setRiftPhase("COOLDOWN", myGeneration)
            task.wait(2)
            riftPostRiftTransition = false
            setRiftPhase("SEARCHING", myGeneration)
            continue
        end

        if monster then
            riftArenaMonster = monster
            RiftStatusLbl.Text = "\xf0\x9f\x90\x89 Mounting and snapping to Rift monster..."
            RiftStatusLbl.TextColor3 = C.gold
            riftArenaSnapDone = mountSnapUnmountRiftMonster(monster)
        else
            RiftStatusLbl.Text = "\xe2\x9a\xa0 Rift monster not found; waiting for arena boss bar..."
            RiftStatusLbl.TextColor3 = C.red
        end

        if not isCurrentRiftLoop(myGeneration) then break end

        RiftStatusLbl.Text = "\xe2\x8f\xb3 Waiting for boss health bar to appear..."
        local uiAppeared = false
        local uiWaitStart = os.clock()

        while isCurrentRiftLoop(myGeneration) and isRiftArenaActive() and os.clock() - uiWaitStart < 12 do
            if isRiftBossAlive() then
                uiAppeared = true
                break
            end
            task.wait(0.15)
        end

        if not uiAppeared then
            RiftStatusLbl.Text = "\xe2\x9a\xa0 Boss health bar never appeared \xe2\x80\x94 leaving..."
            RiftStatusLbl.TextColor3 = C.red
            setRiftPhase("LEAVING", myGeneration)
            riftPostRiftTransition = true
            deactivateRiftArena()
            riftLeaveArena()
            setRiftPhase("CHECKING_PETS", myGeneration)
            maybeAutoHealAfterRift(myGeneration)
            if not isCurrentRiftLoop(myGeneration) then break end
            setRiftPhase("COOLDOWN", myGeneration)
            task.wait(2)
            riftPostRiftTransition = false
            setRiftPhase("SEARCHING", myGeneration)
            continue
        end

        -- If the monster streamed in after the first search, take the same
        -- one-time mount/snap/unmount action now, still inside the arena.
        if not riftArenaSnapDone and isRiftArenaActive() then
            monster = waitForRiftMonster(3, myGeneration)
            if monster and isRiftArenaActive() then
                riftArenaMonster = monster
                RiftStatusLbl.Text = "\xf0\x9f\x90\x89 Mounting and snapping to Rift monster..."
                RiftStatusLbl.TextColor3 = C.gold
                riftArenaSnapDone = mountSnapUnmountRiftMonster(monster)
            end
        end

        if not isCurrentRiftLoop(myGeneration) then break end

        RiftStatusLbl.Text = "\xe2\x9a\x94\xef\xb8\x8f Fighting rift boss..."
        RiftStatusLbl.TextColor3 = C.green
        local fightStart = os.clock()
        local MAX_FIGHT_SECONDS = 180

        while isCurrentRiftLoop(myGeneration) and isRiftArenaActive() and isRiftBossAlive() do
            if os.clock() - fightStart > MAX_FIGHT_SECONDS then
                RiftStatusLbl.Text = "\xe2\x9a\xa0 Fight timeout \xe2\x80\x94 leaving arena"
                RiftStatusLbl.TextColor3 = C.red
                break
            end
            task.wait(0.15)
        end

        if not isCurrentRiftLoop(myGeneration) then break end

        -- Another loop may have already claimed the post-Rift cleanup.
        -- Wait for its leave/heal/return queue to finish instead of
        -- processing the same Rift a second time.
        if riftPostRiftTransition then
            while riftPostRiftTransition and isCurrentRiftLoop(myGeneration) do
                task.wait(0.1)
            end
            continue
        end

        riftKillCount += 1
        RiftKillCountLbl.Text = "\xf0\x9f\x92\x80 Kills this session: " .. riftKillCount

        local leaveDelay = tonumber(riftDelayBeforeLeave) or 1
        -- Hold the next-Rift queue closed through leaving, optional healing,
        -- and the short return cooldown.
        setRiftPhase("LEAVING", myGeneration)
        riftPostRiftTransition = true
        RiftStatusLbl.Text = "\xe2\x9c\x85 Boss defeated \xe2\x80\x94 leaving in " .. leaveDelay .. "s..."
        RiftStatusLbl.TextColor3 = C.green
        task.wait(leaveDelay)
        deactivateRiftArena() -- stop all monster scanning before leaving
        riftLeaveArena()

        -- Healing is deliberately done only after ArenaLeaveChannel. It
        -- never interrupts the active Rift fight or the leave delay.
        setRiftPhase("CHECKING_PETS", myGeneration)
        maybeAutoHealAfterRift(myGeneration)
        if not isCurrentRiftLoop(myGeneration) then break end
        setRiftPhase("COOLDOWN", myGeneration)

        RiftStatusLbl.Text = "\xe2\x8f\xB1 Returned! Waiting 2s for next rift..."
        RiftStatusLbl.TextColor3 = C.sub
        task.wait(2)
        riftPostRiftTransition = false
        setRiftPhase("SEARCHING", myGeneration)
    end
    -- An invalidated/older loop must not reset the state of a newer loop.
    if myGeneration == _G.NoxarRiftLoopGeneration then
        setRiftPhase("IDLE", myGeneration)
        deactivateRiftArena()
        _G.NoxarSetBossMount(false, true)
        RiftStatusLbl.Text = "\xe2\x8f\xB9 Stopped."
        RiftStatusLbl.TextColor3 = C.sub
    end
end

