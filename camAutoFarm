-- Teleports to a saved AreaFarm spot: fires the area-change remote for
-- its AreaID, waits, then snaps the character to the exact saved CFrame.
-- Shared by both Farming Spot TP and the boss loop's "go back" step.
local function teleportToAreaFarmSpot(spot, skipSettle, preSnapWait)
    if not spot then return false end
    pcall(function()
        DataPullFunc:InvokeServer("AreaTeleportToRegionChannel", spot.areaId)
    end)
    task.wait(preSnapWait or 2)
    local r = getRoot()
    if r then
        r.CFrame = CFrame.new(spot.x, spot.y, spot.z)

        -- Wait 5s after arriving, then jump twice (anti-AFK). When
        -- skipSettle is true (boss loop), this runs in the background
        -- instead of blocking the caller, so boss detection can start
        -- immediately after the CFrame snap instead of ~6s later.
        local function settle()
            task.wait(5)
            local char = LP.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hum then
                for i = 1, 2 do
                    hum:ChangeState(Enum.HumanoidStateType.Jumping)
                    task.wait(8) -- short gap so the second jump registers as a new jump
                end
            end
        end

        if skipSettle then
            task.spawn(settle)
        else
            settle()
        end

        return true
    end
    return false
end

