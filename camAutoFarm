end)

task.spawn(function()
    task.wait(3)
    if autoClaimEnabled then
        local ok = claimAll()
        if ok then
            ClaimStatus.Text = "Status: Handled Launch Claim!"
            LastClaimLbl.Text = "Last Claim: " .. os.date("%H:%M:%S")
        end
    end
    while true do
        local secs = getSecondsUntilReset()
        task.wait(secs + 15) 
        if autoClaimEnabled then
            ClaimStatus.Text = "Status: Checking reset payouts..."
            local ok = claimAll()
            if ok then
                ClaimStatus.Text = "Status: Cycle Completed!"
                LastClaimLbl.Text = "Last Claim: " .. os.date("%H:%M:%S")
            end
        end
    end
end)

-- Background Auto Hatch Executor
task.spawn(function()
    while task.wait(5) do
        if not autoHatchEnabled or not selectedEggId then continue end
        
        task.spawn(function()
            for incubatorIndex = 1, 5 do
                if not autoHatchEnabled then break end 
                
                local state = getIncubatorState(incubatorIndex)
                
                if state == "ready" then
                    pcall(function()
                        if EggSystem then
                            EggSystem.ClientHatchTaken(incubatorIndex)
                        else
                            DataPullFunc:InvokeServer("EggHatchTakenChannel", incubatorIndex)
                        end
                    end)
                    task.wait(0.3) 
                    
                elseif state == "empty" then
                    pcall(function()
                        if EggSystem then
                            EggSystem.ClientHatchStart(incubatorIndex, selectedEggId)
                        else
                            DataPullFunc:InvokeServer("EggHatchStartChannel", incubatorIndex, selectedEggId)
                        end
                    end)
                    task.wait(0.3) 
                end
            end
        end)
    end
end)
