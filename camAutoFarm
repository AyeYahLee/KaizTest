local function getRoot()
    local char = LP.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function teleportTo(pos)
    local root = getRoot()
    if root then
        root.CFrame = CFrame.new(pos)
        task.wait(0.05)
    end
end

-- ── Build name map from workspace.SelfGUI ──
-- SelfGUI contains BillboardGuis whose Adornee is the monster's Root part
local nameCache = {}

local function buildNameCache()
    nameCache = {}
    local clientMonsters = workspace:FindFirstChild("ClientMonsters")
    if not clientMonsters then return end

    -- Method 1: read from SelfGUI BillboardGuis
    local selfGui = workspace:FindFirstChild("SelfGUI")
    if selfGui then
        for _, gui in ipairs(selfGui:GetChildren()) do
            if not gui:IsA("BillboardGui") then continue end
            local adornee = gui.Adornee
            if not adornee then continue end
            -- adornee could be topGUI attachment OR the Root part itself
            -- try both: adornee.Parent.Parent and adornee.Parent
            local candidates = {
                adornee.Parent and adornee.Parent.Parent,
                adornee.Parent,
            }
            for _, monster in ipairs(candidates) do
                if monster and monster.Parent == clientMonsters then
                    -- search all TextLabels inside this gui for LabName
                    local labName = gui:FindFirstChild("LabName", true)
                    local labLv = gui:FindFirstChild("LabLv", true)
                    if labName and labName:IsA("TextLabel") and labName.Text ~= "" then
                        nameCache[monster.Name] = {
                            name = labName.Text,
                            level = labLv and labLv.Text or ""
                        }
                    end
                    break
                end
            end
        end
    end

    -- Method 2: search directly inside each monster for any BillboardGui
    for _, monster in ipairs(clientMonsters:GetChildren()) do
        if nameCache[monster.Name] then continue end -- already found
        for _, desc in ipairs(monster:GetDescendants()) do
            if desc:IsA("BillboardGui") then
                local labName = desc:FindFirstChild("LabName", true)
                local labLv = desc:FindFirstChild("LabLv", true)
                if labName and labName:IsA("TextLabel") and labName.Text ~= "" then
                    nameCache[monster.Name] = {
                        name = labName.Text,
                        level = labLv and labLv.Text or ""
                    }
                    break
                end
            end
        end
    end
end

local function getMonsterDisplayName(monster)
    local info = nameCache[monster.Name]
    if info then return info.name end
    return monster.Name
end

local function getMonsterLevel(monster)
    local info = nameCache[monster.Name]
    if info then return info.level end
    return ""
end

-- ── Attack a monster by firing its ClickDetector (same as clicking it) ──
local function attackMonster(monster)
    local root = monster:FindFirstChild("Root")
    if not root then return end
    local cd = root:FindFirstChildOfClass("ClickDetector")
    if not cd then return end
    pcall(function()
        fireclickdetector(cd)
    end)
end

-- ── Scan monster types ──
local function scanMonsterTypes()
    buildNameCache()  -- refresh names from SelfGUI
    local seen = {}
    local types = {}
    local clientMonsters = workspace:FindFirstChild("ClientMonsters")
    if not clientMonsters then return types end

    for _, m in ipairs(clientMonsters:GetChildren()) do
        local displayName = getMonsterDisplayName(m)
        local root = m:FindFirstChild("Root")
        local pos = root and root:IsA("BasePart") and root.Position
            or (m.PrimaryPart and m.PrimaryPart.Position)
        if not seen[displayName] then
            seen[displayName] = true
            local lvl = getMonsterLevel(m)
            table.insert(types, {displayName=displayName, level=lvl, count=1, pos=pos})
        else
            for _, t in ipairs(types) do
                if t.displayName == displayName then t.count += 1; break end
            end
        end
    end
    table.sort(types, function(a,b) return a.displayName < b.displayName end)
    return types
end

-- ── Get target monsters ──
local function getTargetMonsters()
    local clientMonsters = workspace:FindFirstChild("ClientMonsters")
    if not clientMonsters then return {} end
    local monsters = {}
    for _, m in ipairs(clientMonsters:GetChildren()) do
        if selectedMonster then
            local displayName = getMonsterDisplayName(m)
            if not displayName:lower():find(selectedMonster:lower(), 1, true) then
                continue
            end
        end
        local root = m:FindFirstChild("Root")
        local pos = root and root:IsA("BasePart") and root.Position
            or (m.PrimaryPart and m.PrimaryPart.Position)
        if pos then
            table.insert(monsters, {model=m, pos=pos})
        end
    end
    return monsters
end

-- ── Main farm loop ──
local function startFarming(statusLbl)
    local myId = runId
    local killed = 0

    while running and runId == myId do
        buildNameCache()
        local monsters = getTargetMonsters()

        if #monsters == 0 then
            -- No monsters alive — unequip immediately and wait
            currentTarget = nil
            unequipAll()
            statusLbl.Text = "🔍 Waiting for monsters..."
            task.wait(0.5)
            continue
        end

        local target = monsters[1]
        currentTarget = target.model

        -- Teleport first, THEN wait delay, THEN equip
        teleportTo(target.pos)
        unequipAll()  -- make sure unequipped during travel
        task.wait(EQUIP_DELAY)  -- tweakable delay before equipping
        if not running or runId ~= myId then break end
        -- Only equip if monster still alive after delay
        if workspace.ClientMonsters:FindFirstChild(target.model.Name) then
            equipBest()
        else
            continue  -- monster died during delay, loop back
        end

        -- Attack loop
        local spamCount = 0
        while running and runId == myId do
            local stillAlive = workspace.ClientMonsters:FindFirstChild(target.model.Name)
            if not stillAlive then
                killed += 1
                unequipAll()  -- unequip the moment monster dies
                currentTarget = nil
                statusLbl.Text = "⚔️ "..(selectedMonster or "All").." | Killed: "..killed
                break
            end
            attackMonster(target.model)
            spamCount += 1
            if spamCount % 20 == 0 then
                local newRoot = target.model:FindFirstChild("Root")
                if newRoot and newRoot:IsA("BasePart") then
                    local r = getRoot()
                    if r then r.CFrame = CFrame.new(newRoot.Position) end
                end
            end
            task.wait(ATTACK_DELAY)
        end
    end

    currentTarget = nil
    unequipAll()
    statusLbl.Text = "Stopped. Killed: "..killed
end

