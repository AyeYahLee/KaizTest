task.spawn(function()
    local types
    for attempt = 1, 8 do
        task.wait(0.3)
        types = scanMonsterTypes()
        local hasRealNames = false
        for _, t in ipairs(types) do
            if not t.displayName:match("^Monster_%d+$") then
                hasRealNames = true
                break
            end
        end
        if hasRealNames or #types == 0 then break end
    end
    populateList(types)
    ScanBtn.Text = "🔍 Rescan (" .. #types .. " Found)"
end)

