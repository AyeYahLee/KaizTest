-- BOSS TRACKING — replaces the old fixed 20s wait with real detection.
-- Ported from the standalone Monster Tracker test (confirmed working:
-- catches deaths via AncestryChanged/Destroying instantly, 2s poll as
-- a fallback).
-- ==========================================
local BOSS_TRACK_DISTANCE = 60 -- studs; how far from your character to look for the boss

local function getBossMonsterPos(m)
    local root = m:FindFirstChild("Root")
        or m:FindFirstChild("HumanoidRootPart")
        or m.PrimaryPart

    if root and root:IsA("BasePart") then
        return root.Position
    end

    for _, obj in ipairs(m:GetDescendants()) do
        if obj:IsA("BasePart") then
            return obj.Position
        end
    end
    return nil
end

local function findNearestBoss()
    local hrp = getRoot()
    if not hrp then return nil end
    buildNameCache()

    local nearest, nearestDist = nil, math.huge
    for _, m in ipairs(clientMonsters:GetChildren()) do
        local pos = getBossMonsterPos(m)
        if pos then
            local dist = (hrp.Position - pos).Magnitude
            if dist <= BOSS_TRACK_DISTANCE and dist < nearestDist then
                nearest, nearestDist = m, dist
            end
        end
    end
    return nearest
end

-- Waits indefinitely (no timeout) until a boss spawns nearby, then waits
-- until that exact instance is defeated/removed. Bails out early if the
-- boss loop gets toggled off while waiting at any point.
local function waitForBossThenDefeat()
    -- Phase 1: stay put and keep checking until the boss actually spawns
    local target
    while bossLoopEnabled do
        target = findNearestBoss()
        if target then break end
        task.wait(1)
    end
    if not bossLoopEnabled or not target then return end

    local info = nameCache[target.Name]
    local displayName = info and info.name or target.Name
    BossLoopLiveStatusLbl.Text = "Status: Boss found (" .. displayName .. "), fighting..."
    BossLoopLiveStatusLbl.TextColor3 = C.gold

    -- Phase 2: wait until this specific boss instance is gone
    local defeated = false
    local ancestryConn, destroyingConn

    local function markDefeated()
        if defeated then return end
        defeated = true
        if ancestryConn then ancestryConn:Disconnect() end
        if destroyingConn then destroyingConn:Disconnect() end
    end

    ancestryConn = target.AncestryChanged:Connect(function(_, parent)
        if parent ~= clientMonsters then markDefeated() end
    end)
    destroyingConn = target.Destroying:Connect(markDefeated)

    while not defeated and bossLoopEnabled do
        if not clientMonsters:FindFirstChild(target.Name) then
            markDefeated()
            break
        end
        task.wait(2)
    end

    -- Covers the case where we exited because bossLoopEnabled went false
    -- mid-fight rather than because the boss died — markDefeated() is a
    -- no-op if already called, so this just guarantees the two
    -- connections are always cleaned up before this function returns.
    markDefeated()
end

-- Background watcher: fires once per UTC 15-minute mark while the loop
-- is enabled. Uses os.date("!*t") the same way getSecondsUntilReset()
-- above already does for UTC time in this file.
spawnTracked("bossLoop", function()
    while task.wait(1) do
        if not bossLoopEnabled then continue end
        if not farmingSpot or not bossSpot then continue end

        local t = os.date("!*t")
        local isQuarterMark = (t.min % 15 == 0) and (t.sec <= 2)
        local markKey = string.format("%d-%d-%d %d:%d", t.year, t.month, t.day, t.hour, t.min)

        if isQuarterMark and lastBossTrigger ~= markKey then
            lastBossTrigger = markKey

            task.spawn(function()
                BossLoopLiveStatusLbl.Text = "Status: Teleporting to Boss..."
                BossLoopLiveStatusLbl.TextColor3 = C.gold
                task.wait(7) -- delay before firing the teleport itself
                teleportToAreaFarmSpot(bossSpot, true) -- skipSettle=true, preSnapWait stays default (2) so detection starts fast right after the CFrame snap

                BossLoopLiveStatusLbl.Text = "Status: At Boss, waiting for it to spawn..."
                waitForBossThenDefeat()

                if not bossLoopEnabled then return end -- got turned off mid-wait

                BossLoopLiveStatusLbl.Text = "Status: Boss defeated! Waiting 3s..."
                task.wait(3)

                if not bossLoopEnabled then return end -- got turned off mid-wait

                BossLoopLiveStatusLbl.Text = "Status: Returning to Farming Spot..."
                teleportToAreaFarmSpot(farmingSpot, false, 7)

                BossLoopLiveStatusLbl.Text = "Status: Waiting for next :00/:15/:30/:45..."
                BossLoopLiveStatusLbl.TextColor3 = C.sub
            end)
        end
    end
end)

