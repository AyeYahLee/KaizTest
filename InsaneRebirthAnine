local autoRunning = false
local totalFired = 0

local function getAmount() return tonumber(amtBox.Text) or 100 end
local function getBurst()  return tonumber(burstBox.Text) or 120 end
local function getRest()   return tonumber(restBox.Text) or 10 end

local function fireRebirth(amount)
    for i = 1, amount do
        task.spawn(function()
            ReplicatedStorage.Events.RequestRebirth:FireServer()
        end)
    end
    totalFired = totalFired + amount
end

onceBtn.MouseButton1Click:Connect(function()
    fireRebirth(getAmount())
    statusLbl.Text = "✅ Fired " .. getAmount() .. "x | Total: " .. totalFired
    statusLbl.TextColor3 = Color3.fromRGB(100, 220, 100)
end)

autoBtn.MouseButton1Click:Connect(function()
    autoRunning = not autoRunning
    if autoRunning then
        autoBtn.Text = "🤖 Auto Rebirth: ON"
        autoBtn.BackgroundColor3 = Color3.fromRGB(120, 60, 255)
        totalFired = 0
        task.spawn(function()
            while autoRunning do
                -- BURST PHASE
                local burstEnd = tick() + getBurst()
                while autoRunning and tick() < burstEnd do
                    fireRebirth(getAmount())
                    local remaining = math.ceil(burstEnd - tick())
                    statusLbl.Text = "♻️ Firing | " .. remaining .. "s left | Total: " .. totalFired
                    statusLbl.TextColor3 = Color3.fromRGB(100, 220, 100)
                    task.wait(0.05)
                end
                if not autoRunning then break end
                -- REST PHASE
                local restEnd = tick() + getRest()
                while autoRunning and tick() < restEnd do
                    local remaining = math.ceil(restEnd - tick())
                    statusLbl.Text = "💤 Resting | " .. remaining .. "s left | Total: " .. totalFired
                    statusLbl.TextColor3 = Color3.fromRGB(130, 130, 180)
                    task.wait(0.5)
                end
            end
            statusLbl.Text = "⏹ Stopped | Total fired: " .. totalFired
            statusLbl.TextColor3 = Color3.fromRGB(130, 130, 140)
        end)
    else
        autoRunning = false
        autoBtn.Text = "🤖 Auto Rebirth: OFF"
        autoBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
    end
end)
