    CurrentValue = false,
    Callback = function(on)
        chestRunning = on

        for _, c in pairs(chestConnections) do
            pcall(function() c:Disconnect() end)
        end
        chestConnections = {}

        if not on then return end

        local char = LP.Character or LP.CharacterAdded:Wait()
        local root = char:WaitForChild("HumanoidRootPart")
        local ChestSpawns = workspace:WaitForChild("ChestSpawns")
        local claimed = false

        local function handleChest(chest)
    if not chestRunning or claimed then return end
    claimed = true

    root.CFrame = CFrame.new(chest.Position + Vector3.new(0,4,0))
    task.wait(0.2)

    for i = 1, 3 do
        for _,v in pairs(chest:GetDescendants()) do
            if v:IsA("ProximityPrompt") then
                pcall(function() fireproximityprompt(v) end)
            end
        end
        pcall(function() fireproximityprompt(chest) end)
        pcall(function()
            local cc = Remotes.ChestClaimed
            if cc:IsA("RemoteFunction") then
                cc:InvokeServer(chest)
            else
                cc:FireServer(chest)
            end
        end)
        task.wait(0.1)
    end

    local conn
    conn = chest:GetPropertyChangedSignal("Transparency"):Connect(function()
        if chest.Transparency >= 0.9 then
            claimed = false
            if conn then conn:Disconnect(); conn=nil end
        end
    end)
    task.delay(10, function()
        claimed = false
        if conn then conn:Disconnect(); conn=nil end
    end)
end

        for _, chest in pairs(ChestSpawns:GetChildren()) do
            if chest:IsA("MeshPart") then
                if chest.Transparency < 0.5 then
                    task.spawn(function() handleChest(chest) end)
                end
                local c = chest:GetPropertyChangedSignal("Transparency"):Connect(function()
                    if chest.Transparency < 0.5 and not claimed then
                        task.spawn(function() handleChest(chest) end)
                    end
                end)
                table.insert(chestConnections, c)
            end
        end
    end
}, "AutoCollectChests")
