-- Known mutation keywords — last word is only treated as a mutation if it matches one of these
local MUTATIONS = {
    secret=true, rainbow=true, golden=true, shiny=true, inverted=true,
    cosmic=true, mythic=true, legendary=true, admin=true, heavenly=true,
    corrupted=true, frozen=true, ghostly=true, spotted=true, windy=true,
    lucky=true, inferno=true, surge=true, astral=true, phantom=true,
    orbital=true, flare=true, lunar=true, icy=true,
}
local function parseCowSpec(spec)
    local parts = spec:split(" ")
    if #parts >= 2 then
        local lastWord = parts[#parts]:lower()
        if MUTATIONS[lastWord] then
            return table.concat(parts, " ", 1, #parts-1):lower(), lastWord
        end
    end
    return spec:lower(), nil
end

local function searchCache(cache, name, mutation)
    local matches = cache[name]
    if not matches or #matches == 0 then
        for k, v in pairs(cache) do
            if k:find(name, 1, true) then matches = v; break end
        end
    end
    if not matches or #matches == 0 then return nil, nil end
    if mutation then
        for _, e in ipairs(matches) do
            if e.mutation:lower() == mutation then return e.id, e.name end
        end
    end
    return matches[1].id, matches[1].name
end

local function getCowUUID(spec, statusLbl)
    if not spec or spec == "" then return nil, nil end
    local name, mutation = parseCowSpec(spec)
    local uid, cname = searchCache(hotbar, name, mutation)
    if uid then return uid, cname end
    uid, cname = searchCache(inventory, name, mutation)
    if not uid then
        statusLbl.Text = "⚠️ '"..spec.."' not found!\nOpen inventory once first."
        return nil, nil
    end
    if placedUUIDs[uid] then
        local matches = inventory[name]
        if matches then
            for _, e in ipairs(matches) do
                if not placedUUIDs[e.id] then
                    if not mutation or e.mutation:lower() == mutation then
                        uid = e.id; cname = e.name; break
                    end
                end
            end
        end
        if placedUUIDs[uid] then
            statusLbl.Text = "⚠️ All '"..spec.."' already placed."
            return nil, nil
        end
    end
    statusLbl.Text = "📦 Moving '"..cname.."' → hotbar..."
    pcall(function() Remotes.SetHotbarSlot:FireServer(1, uid) end)
    local elapsed = 0
    while elapsed < 1.5 do
        task.wait(0.1); elapsed += 0.1
        local huid, hname = searchCache(hotbar, name, mutation)
        if huid then return huid, hname end
    end
    return uid, cname
end

-- ── Place logic ───────────────────────────────────────────────────────────────
local function placeInStable(slot, cowSpec, statusLbl)
    local uuid, cowName = getCowUUID(cowSpec, statusLbl)
    if not uuid then return false end
    pcall(function() Remotes.SetHotbarSlot:FireServer(1, uuid) end)
    task.wait(0.15)
    pcall(function() Remotes.SelectCow:FireServer(uuid) end)
    task.wait(0.2)
    local root = slot:FindFirstChild("Root")
    if root and root:IsA("BasePart") then teleportTo(root.Position)
    else
        local base = slot:FindFirstChildWhichIsA("BasePart")
        if base then teleportTo(base.Position) end
    end
    if not running then return false end
    for _, desc in ipairs(slot:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and desc.Name == "PickupPrompt" then
            statusLbl.Text = slot.Parent.Name.." › "..slot.Name.."\n🐄 "..(cowName or cowSpec)
            firePrompt(desc); task.wait(DELAY); return true
        end
    end
    for _, desc in ipairs(slot:GetDescendants()) do
        if desc:IsA("ProximityPrompt") then
            firePrompt(desc); task.wait(DELAY); return true
        end
    end
    return false
end

local function placeFloor(plot, floorNum, statusLbl)
    if not running then return 0 end
    local floor = plot:FindFirstChild("Floor"..floorNum)
    if not floor then return 0 end
    local cowSpec = floorCowMap[floorNum] or defaultCow
    if cowSpec == "" then return 0 end
    local count = 0
    for _, slot in ipairs(floor:GetChildren()) do
        if not slot.Name:find("Stable") then continue end
        if not running then return count end
        if not stableIsEmpty(slot) then continue end
        if placeInStable(slot, cowSpec, statusLbl) then count += 1 end
    end
    return count
end

local function startPlacing(statusLbl)
    local myId = runId
    local total = 0
    -- Wait for inventory/hotbar to populate (need open backpack)
    if next(inventory) == nil and next(hotbar) == nil then
        statusLbl.Text = "⚠️ Open your backpack\nto load inventory..."
        local waited = 0
        repeat task.wait(0.3); waited += 0.3 until (next(inventory) ~= nil or next(hotbar) ~= nil) or waited >= 20
    end
    if next(inventory) == nil and next(hotbar) == nil then
        statusLbl.Text = "❌ Inventory not loaded.\nOpen backpack & try again."
        running = false; return
    end
    task.wait(0.3)
    while running and runId == myId do
        local plot = getPlot()
        if not plot then statusLbl.Text = "⚠️ Plot not found"; task.wait(2); continue end
        local placed = 0
        for f = FLOOR_MIN, FLOOR_MAX do
            if not running or runId ~= myId then break end
            local n = placeFloor(plot, f, statusLbl)
            placed += n; total += n
        end
        if running and runId == myId then
            statusLbl.Text = placed == 0
                and ("✅ All full! Total: "..total.."\nWatching...")
                or ("+"..placed.." placed! Total: "..total.."\nLooping...")
            task.wait(2)
        end
    end
    statusLbl.Text = "Stopped. Total: "..total
end

-- ── Auto Favourite logic ──────────────────────────────────────────────────────
-- Reads BackpackGui directly. FavoriteIcon.Visible=true means already faved.
-- Clicks TextButton on unfaved matching cows. No remote needed.
local favSpecs = {}
local favRunning = false
local favRunId = 0

-- uuid -> {name, mutation} built from hotbar+inventory caches
local guiCowCache = {}
local function rebuildGuiCache()
    guiCowCache = {}
    for _, entries in pairs(hotbar) do
        for _, e in ipairs(entries) do
            guiCowCache[e.id] = {name=e.name:lower(), mutation=e.mutation:lower()}
        end
    end
    for _, entries in pairs(inventory) do
        for _, e in ipairs(entries) do
            if not guiCowCache[e.id] then
                guiCowCache[e.id] = {name=e.name:lower(), mutation=e.mutation:lower()}
            end
        end
    end
end

local function getBackpackList()
    local bg = LP.PlayerGui:FindFirstChild("BackpackGui")
    if not bg then return nil end
    local bp = bg:FindFirstChild("Backpack")
    if not bp then return nil end
    local inv = bp:FindFirstChild("Inventory")
    if not inv then return nil end
    return inv:FindFirstChild("list")
end

-- Find the search box inside BackpackGui
local function getSearchBox()
    local bg = LP.PlayerGui:FindFirstChild("BackpackGui")
    if not bg then return nil end
    for _, desc in ipairs(bg:GetDescendants()) do
        if desc:IsA("TextBox") and (desc.Name:lower():find("search") or desc.PlaceholderText:lower():find("search")) then
            return desc
        end
    end
    local bp = bg:FindFirstChild("Backpack")
    if bp then
        for _, desc in ipairs(bp:GetDescendants()) do
            if desc:IsA("TextBox") then return desc end
        end
    end
    return nil
end

local function startFavouring(favStatusLbl)
    local myId = favRunId
    local total = 0

    favStatusLbl.Text = "⭐ Open your backpack!"
    local list = getBackpackList()
    local waited = 0
    while not list and waited < 15 do
        task.wait(0.3); waited += 0.3
        list = getBackpackList()
    end
    if not list then
        favStatusLbl.Text = "❌ Backpack not found.\nOpen it manually!"
        favRunning = false; return
    end

    task.wait(0.3)
    rebuildGuiCache()

    -- Single pass over entire list, match by guiCowCache name/mutation
    -- No search box — it messes up the list visibility
    local did = 0
    for _, cowFrame in ipairs(list:GetChildren()) do
        if not favRunning or favRunId ~= myId then break end
        if cowFrame.Name:sub(1,4) ~= "Cow_" then continue end

        local favIcon = cowFrame:FindFirstChild("FavoriteIcon")
        if favIcon and favIcon.Visible then continue end -- already faved

        local cowUuid = cowFrame.Name:sub(5)
        local cowInfo = guiCowCache[cowUuid]

        -- Also try to read cow name from the BG ImageLabel tooltip or CowImage Image asset
        -- The game sets CowImage.Image to an asset that encodes the cow type
        if not cowInfo then
            -- Try to get name from any child TextLabel
            for _, child in ipairs(cowFrame:GetDescendants()) do
                if child:IsA("TextLabel") and child.Text and child.Text ~= "" then
                    local t = child.Text:lower()
                    if #t > 2 then
                        guiCowCache[cowUuid] = {name=t, mutation=""}
                        cowInfo = guiCowCache[cowUuid]
                        break
                    end
                end
            end
        end

        -- Check if this cow matches any selected spec
        local matched = false
        for _, spec in ipairs(favSpecs) do
            local specName, specMutation = parseCowSpec(spec)
            if cowInfo then
                local nameMatch = cowInfo.name:find(specName, 1, true) ~= nil
                local mutMatch = (not specMutation) or cowInfo.mutation:find(specMutation, 1, true) ~= nil
                if nameMatch and mutMatch then matched = true; break end
            end
        end

        if matched then
            favStatusLbl.Text = "⭐ Faving: "..(cowInfo.name).." "..(cowInfo.mutation).." ("..total..")"
            pcall(function() Remotes.ToggleFavoriteCow:FireServer(cowUuid) end)
            total += 1; did += 1
            task.wait(0.15)
        end
    end

    favStatusLbl.Text = "✅ Done! Total faved: "..total
    favRunning = false
end


-- ── Auto Collect Logic ───────────────────────────────────────────────────────
local collectRunning = false
local collectRunId = 0
local COLLECT_DELAY = 0.25
local COLLECT_FIRE_REPEATS = 5
local COLLECT_FIRE_INTERVAL = 0.05
local COLLECT_FLOOR_MIN = 1
local COLLECT_FLOOR_MAX = 13

local function collectFirePrompt(prompt)
    for i = 1, COLLECT_FIRE_REPEATS do
        if not collectRunning then break end
        pcall(function() fireproximityprompt(prompt) end)
        task.wait(COLLECT_FIRE_INTERVAL)
    end
end

local function collectFloor(plot, floorName)
    if not collectRunning then return 0 end
    local floor = plot:FindFirstChild(floorName)
    if not floor then return 0 end
    local count = 0
    for _, slot in ipairs(floor:GetChildren()) do
        if not slot.Name:find("Stable") then continue end
        if not collectRunning then return count end
        local stableRoot = slot:FindFirstChildWhichIsA("BasePart")
        if stableRoot then
            local char = LP.Character
            if char then
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then
                    root.CFrame = CFrame.new(stableRoot.Position + Vector3.new(0,3,0))
                    task.wait(0.1)
                end
            end
        end
        for _, cow in ipairs(slot:GetChildren()) do
            if not cow.Name:find("Cow_") then continue end
            if not collectRunning then return count end
            for _, desc in ipairs(cow:GetDescendants()) do
                if desc:IsA("ProximityPrompt") and desc.Name == "PickupPrompt" then
                    collectFirePrompt(desc)
                    count += 1
                    task.wait(COLLECT_DELAY)
                    break
                end
            end
        end
    end
    return count
end

local function startCollecting()
    local myId = collectRunId
    local total = 0
    while collectRunning and collectRunId == myId do
        local plot = getPlot()
        if not plot then task.wait(2); continue end
        for f = COLLECT_FLOOR_MIN, COLLECT_FLOOR_MAX do
            if not collectRunning or collectRunId ~= myId then break end
            total += collectFloor(plot, "Floor"..f)
        end
        task.wait(0.5)
    end
end

