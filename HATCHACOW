-- CHEST FARMER
MiscTab:CreateParagraph({ Title = "Chest Farmer", Text = "Teleport to and collect chests automatically." })

MiscTab:CreateToggle({
    Name = "Auto Collect Chests",
    Description = "Teleports to chests and collects them when they spawn.",
    CurrentValue = false,
    Callback = function(on)
        chestRunning = on
        if not on then
            if chestConnection then
                chestConnection:Disconnect()
                chestConnection = nil
            end
            return
        end
        local char = LP.Character or LP.CharacterAdded:Wait()
        local root = char:WaitForChild("HumanoidRootPart")
        local ChestSpawns = workspace:WaitForChild("ChestSpawns")
        local claimed = false
        chestConnection = ChestSpawns.ChildAdded:Connect(function(child)
            if not chestRunning or claimed then return end
            claimed = true
            task.wait(0.05)
            local part = nil
            if child:IsA("BasePart") then
                part = child
            else
                part = child:FindFirstChildOfClass("BasePart")
                if not part then
                    for _, v in pairs(child:GetDescendants()) do
                        if v:IsA("BasePart") then part = v; break end
                    end
                end
            end
            if part then
                root.CFrame = CFrame.new(part.Position + Vector3.new(0, 4, 0))
            elseif child:IsA("Model") then
                local ok, pos = pcall(function() return child:GetPivot().Position end)
                if ok then root.CFrame = CFrame.new(pos + Vector3.new(0, 4, 0)) end
            end
            task.wait(0.2)
            for _, v in pairs(child:GetDescendants()) do
                if v:IsA("ProximityPrompt") then
                    pcall(function() fireproximityprompt(v) end)
                end
            end
            pcall(function()
                local cc = Remotes.ChestClaimed
                if cc:IsA("RemoteFunction") then
                    cc:InvokeServer(child)
                else
                    cc:FireServer(child)
                end
            end)
            task.delay(8, function()
                claimed = false
            end)
        end)
    end
}, "AutoCollectChests")
