Remotes.HotbarUpdate.OnClientEvent:Connect(function(data)
    hotbar = {}
    if type(data) ~= "table" then return end
    for _, slot in pairs(data) do
        if type(slot) == "table" and slot.kind == "cow" and slot.id then
            local key = slot.name:lower()
            if not hotbar[key] then hotbar[key] = {} end
            table.insert(hotbar[key], {id=slot.id, name=slot.name, mutation=slot.mutation or ""})
        end
    end
end)

-- ── Inventory listener (flat, no recursion) ───────────────────────────────────
local function addToInventory(id, name, mutation, favorite)
    local key = name:lower()
    if not inventory[key] then inventory[key] = {} end
    for _, e in ipairs(inventory[key]) do
        if e.id == id then
            e.favorite = favorite; return  -- update favorite flag in place
        end
    end
    table.insert(inventory[key], {id=id, name=name, mutation=mutation or "", favorite=favorite})
end

-- Track which UUIDs are already favourited from FavoritesUpdate remote
local serverFavorites = {}
pcall(function()
    Remotes.FavoritesUpdate.OnClientEvent:Connect(function(data)
        if type(data) ~= "table" then return end
        serverFavorites = {}
        for uuid, val in pairs(data) do
            if val == true then serverFavorites[uuid] = true end
        end
        -- Sync into inventory cache
        for _, entries in pairs(inventory) do
            for _, e in ipairs(entries) do
                e.favorite = serverFavorites[e.id] == true
            end
        end
    end)
end)

Remotes.InventoryUpdate.OnClientEvent:Connect(function(data)
    if type(data) ~= "table" then return end

    inventory = {}
    placedUUIDs = {}

    -- Track placed UUIDs
    if type(data.placed) == "table" then
        for _, uuid in pairs(data.placed) do
            if type(uuid) == "string" then placedUUIDs[uuid] = true end
        end
    end

    -- The inventory data is a flat table where values can be cow entries.
    -- A cow entry looks like: {id=string, name=string, egg=string, mutation=string, kind="cow"}
    -- We do a single-level scan of all values (no deep recursion).
    local function scanLevel(t)
        if type(t) ~= "table" then return end
        for _, v in pairs(t) do
            if type(v) == "table"
                and type(v.id) == "string"
                and type(v.name) == "string"
                and v.kind ~= "crop"
                and v.egg ~= nil  -- cows always have an egg field
            then
                local isFav = serverFavorites[v.id] == true or v.favorite == true
                addToInventory(v.id, v.name, v.mutation, isFav)
            end
        end
    end

    -- Scan top-level and one level deep (covers both flat and grouped layouts)
    scanLevel(data)
    for _, v in pairs(data) do
        if type(v) == "table" then
            scanLevel(v)
        end
    end
end)

