local function getPlot()
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return nil end
    for _, plot in ipairs(plots:GetChildren()) do
        local root = plot:FindFirstChild("Root")
        if root then
            local billboard = root:FindFirstChild("PlotBillboard")
            if billboard then
                local lbl = billboard:FindFirstChild("TextLabel")
                if lbl and string.find(lbl.Text, LP.DisplayName, 1, true) then
                    return plot
                end
            end
        end
    end
end

local function claimCash()
    if tick() - lastClaim < delay - 0.1 then return end
    lastClaim = tick()
    local plot = getPlot()
    if not plot then return end
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    for _, child in ipairs(plot:GetChildren()) do
        if child.Name:match("^Floor%d+$") then
            for _, obj in ipairs(child:GetChildren()) do
                local pad = obj:FindFirstChild("CollectPad")
                if pad then
                    local part = pad:FindFirstChild("Part")
                    if part then
                        pcall(function()
                            firetouchinterest(hrp, part, 0)
                            task.wait(0.02)
                            firetouchinterest(hrp, part, 1)
                        end)
                    end
                end
            end
        end
    end
end

local function getEggs()
    local fallback = {
        "Basic", "Aquatic", "Midnight", "Alien",
        "Snow", "Candy", "Bird", "Insect", "Elemental"
    }
    local gui = LP.PlayerGui:FindFirstChild("EggShopGui")
    if not gui then return fallback end
    local ok, scroll = pcall(function()
        return gui.Frame.Holder.ScrollingFrame
    end)
    if not ok or not scroll then return fallback end
    local list = {}
    for _, item in ipairs(scroll:GetChildren()) do
        local nameLabel   = item:FindFirstChild("NameLabel")
        local rarityLabel = item:FindFirstChild("RarityLuckLabel")
        if nameLabel and rarityLabel and nameLabel.Text ~= "Name" then
            local name = nameLabel.Text:gsub("%s*Egg$", "")
            local tier = tonumber(rarityLabel.Text:match("Tier%s*(%d+)")) or 0
            table.insert(list, {Name=name, Tier=tier})
        end
    end
    if #list == 0 then return fallback end
    table.sort(list, function(a,b) return a.Tier < b.Tier end)
    local eggs = {}
    for _, e in ipairs(list) do table.insert(eggs, e.Name) end
    return eggs
end

