local function getSellMenu()
    local ok, result = pcall(function()
        return player.PlayerGui.GUI.Frames.Sell.ShopContainer.ScrollingFrame
    end)
    if ok then return result end
    return nil
end

local function trySellItem(item)
    if not (item:IsA("Frame") or item:IsA("ImageButton") or item:IsA("TextButton")) then return end
    local rarityLabel = item:FindFirstChild("Rarity", true)
    if rarityLabel and rarityLabel:IsA("TextLabel") then
        local rarity = rarityLabel.Text
        if SELL_RARITIES[rarity] then
            pcall(function()
                RequestSell:FireServer("Single", item.Name)
            end)
            sellStatusLbl.Text = "⚡ Auto sold: " .. rarity .. " (" .. item.Name:sub(1,8) .. "...)"
            return true
        end
    end
    return false
end

-- SELL NOW button
local sellNowBtn = Instance.new("TextButton", sellPage)
sellNowBtn.Size = UDim2.new(1,0,0,38)
sellNowBtn.BackgroundColor3 = Color3.fromRGB(60,60,80)
sellNowBtn.Text = "💰  SELL NOW"
sellNowBtn.TextColor3 = Color3.fromRGB(255,255,255)
sellNowBtn.TextSize = 13
sellNowBtn.Font = Enum.Font.GothamBold
sellNowBtn.BorderSizePixel = 0
sellNowBtn.LayoutOrder = nextOrder()
Instance.new("UICorner", sellNowBtn).CornerRadius = UDim.new(0,11)

sellNowBtn.MouseButton1Click:Connect(function()
    if sellRunning then return end
    local scrolling = getSellMenu()
    if not scrolling then
        sellStatusLbl.Text = "❌ Open the Sell menu first!"
        return
    end
    sellRunning = true
    sellNowBtn.Text = "Selling..."
    sellNowBtn.BackgroundColor3 = Color3.fromRGB(40,40,60)
    task.spawn(function()
        local sold = 0
        for _, item in ipairs(scrolling:GetChildren()) do
            if not sellRunning then break end
            if trySellItem(item) then
                sold += 1
                task.wait(SELL_DELAY)
            end
        end
        sellStatusLbl.Text = "✅ Done! Sold " .. sold .. " items."
        sellRunning = false
        sellNowBtn.Text = "💰  SELL NOW"
        sellNowBtn.BackgroundColor3 = Color3.fromRGB(60,60,80)
    end)
end)

-- AUTO SELL toggle
local autoSellBtn = Instance.new("TextButton", sellPage)
autoSellBtn.Size = UDim2.new(1,0,0,38)
autoSellBtn.BackgroundColor3 = Color3.fromRGB(40,40,60)
autoSellBtn.Text = "🤖  AUTO SELL: OFF"
autoSellBtn.TextColor3 = Color3.fromRGB(255,255,255)
autoSellBtn.TextSize = 13
autoSellBtn.Font = Enum.Font.GothamBold
autoSellBtn.BorderSizePixel = 0
autoSellBtn.LayoutOrder = nextOrder()
Instance.new("UICorner", autoSellBtn).CornerRadius = UDim.new(0,11)

autoSellBtn.MouseButton1Click:Connect(function()
    autoSellRunning = not autoSellRunning

    if autoSellRunning then
        autoSellBtn.Text = "🤖  AUTO SELL: ON"
        autoSellBtn.BackgroundColor3 = Color3.fromRGB(180,40,40)
        sellStatusLbl.Text = "👀 Watching for items..."

        -- First sell anything already in the menu
        local scrolling = getSellMenu()
        if scrolling then
            for _, item in ipairs(scrolling:GetChildren()) do
                if trySellItem(item) then
                    task.wait(SELL_DELAY)
                end
            end
            -- Then watch for new items added
            autoSellConnection = scrolling.ChildAdded:Connect(function(item)
                if not autoSellRunning then return end
                task.wait(0.2) -- wait for rarity label to populate
                if trySellItem(item) then
                    task.wait(SELL_DELAY)
                end
            end)
        else
            sellStatusLbl.Text = "❌ Open the Sell menu first!"
            autoSellRunning = false
            autoSellBtn.Text = "🤖  AUTO SELL: OFF"
            autoSellBtn.BackgroundColor3 = Color3.fromRGB(40,40,60)
        end
    else
        autoSellBtn.Text = "🤖  AUTO SELL: OFF"
        autoSellBtn.BackgroundColor3 = Color3.fromRGB(40,40,60)
        sellStatusLbl.Text = "⏹ Auto sell stopped."
        if autoSellConnection then
            autoSellConnection:Disconnect()
            autoSellConnection = nil
        end
    end
end)

