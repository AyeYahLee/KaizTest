local function createTab(name,icon)
    local tb = Instance.new("TextButton",tabBar)
    tb.Size = UDim2.new(0,50,1,0)
    tb.BackgroundColor3 = Color3.fromRGB(30,30,45)
    tb.Text = icon.." "..name
    tb.TextColor3 = Color3.fromRGB(150,150,170)
    tb.Font = Enum.Font.GothamBold
    tb.TextSize = 9
    tb.BorderSizePixel = 0
    Instance.new("UICorner",tb).CornerRadius = UDim.new(0,9)

    local pg = Instance.new("ScrollingFrame",main)
    pg.Size = UDim2.new(1,-14,1,-82)
    pg.Position = UDim2.new(0,7,0,80)
    pg.BackgroundTransparency = 1
    pg.BorderSizePixel = 0
    pg.ScrollBarThickness = 2
    pg.ScrollBarImageColor3 = Color3.fromRGB(120,60,255)
    pg.CanvasSize = UDim2.new(0,0,0,0)
    pg.AutomaticCanvasSize = Enum.AutomaticSize.Y
    pg.Visible = false
    local pgl = Instance.new("UIListLayout",pg)
    pgl.Padding = UDim.new(0,6)
    pgl.HorizontalAlignment = Enum.HorizontalAlignment.Center
    pgl.SortOrder = Enum.SortOrder.LayoutOrder
    local pgp = Instance.new("UIPadding",pg)
    pgp.PaddingTop = UDim.new(0,4)
    pgp.PaddingBottom = UDim.new(0,8)

    pages[name] = pg; tabBtns[name] = tb
    tb.MouseButton1Click:Connect(function()
        for n,p in pairs(pages) do
            p.Visible = false
            tabBtns[n].BackgroundColor3 = Color3.fromRGB(30,30,45)
            tabBtns[n].TextColor3 = Color3.fromRGB(150,150,170)
        end
        pg.Visible = true
        tb.BackgroundColor3 = Color3.fromRGB(120,60,255)
        tb.TextColor3 = Color3.fromRGB(255,255,255)
    end)
    return pg
end

