local function makeChip(parent,txt,isOn,onChange)
    local btn = Instance.new("TextButton",parent)
    btn.Size = UDim2.new(0,50,1,0)
    btn.BackgroundColor3 = isOn and Color3.fromRGB(120,60,255) or Color3.fromRGB(40,40,58)
    btn.Text = txt
