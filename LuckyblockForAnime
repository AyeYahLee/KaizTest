-- CLAIM FUNCTIONS
local function claimAll()
    local ok1 = pcall(function()
        DataPullFunc:InvokeServer("TowerTakeDailyRewardAllChannel")
    end)
    local ok2 = pcall(function()
        DataPullFunc:InvokeServer("ChestRewardTakeDailyChestChannel", 1)
    end)
    local ok3 = pcall(function()
        DataPullFunc:InvokeServer("TaskClaimRewardChannel", 205)
    end)
    local ok4 = pcall(function()
        DataPullFunc:InvokeServer("TaskClaimRewardChannel", 102)
    end)
    local ok5 = pcall(function()
        DataPullFunc:InvokeServer("ChestRewardTakeDailyRewardChannel", 1)
    end)
    return ok1 and ok2 and ok3 and ok4 and ok5
end

local function getSecondsUntilReset()
    local t = os.date("!*t")
    local now = t.hour * 3600 + t.min * 60 + t.sec
    local diff = 86400 - now
    if diff <= 30 then diff = diff + 86400 end
    return diff
end

local function formatTime(s)
    local h = math.floor(s / 3600)
    local m = math.floor((s % 3600) / 60)
    local sec = math.floor(s % 60)
    return string.format("%02d:%02d:%02d", h, m, sec)
end

