local order = 0
local function nextOrder() order=order+1; return order end

local function makeToggle(parent,offT,onT,offC,onC,cb)
    local btn = Instance.new("TextButton",parent)
    btn.Size = UDim2.new(1,0,0,42)
    btn.BackgroundColor3 = offC
    btn.Text = offT
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 13
    btn.BorderSizePixel = 0
    btn.LayoutOrder = nextOrder()
    Instance.new("UICorner",btn).CornerRadius = UDim.new(0,11)
    local tog = false
    btn.MouseButton1Click:Connect(function()
        tog = not tog
        btn.BackgroundColor3 = tog and onC or offC
        btn.Text = tog and onT or offT
        cb(tog)
    end)
    return btn
end

local function makeStatus(parent)
    local l = Instance.new("TextLabel",parent)
    l.Size = UDim2.new(1,0,0,14)
    l.BackgroundTransparency = 1
    l.Text = ""
    l.TextColor3 = Color3.fromRGB(130,130,140)
    l.Font = Enum.Font.Gotham
    l.TextSize = 10
    l.LayoutOrder = nextOrder()
    return l
end

local function makeSectionLbl(parent,txt)
    local l = Instance.new("TextLabel",parent)
