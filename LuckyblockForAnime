-- AUTO CLAIM LOOP
task.spawn(function()
    task.wait(2)
    if autoEnabled then
        StatusLabel.Text = "Status: Claiming..."
        StatusLabel.TextColor3 = Color3.fromRGB(255, 220, 50)
        local ok = claimAll()
        if ok then
            StatusLabel.Text = "Status: Claimed!"
            StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 150)
            LastLabel.Text = "Last Claim: " .. os.date("%H:%M:%S")
        else
            StatusLabel.Text = "Status: Failed"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        end
    end

    while true do
        local secs = getSecondsUntilReset()
        task.wait(secs + 30)
        if autoEnabled then
            StatusLabel.Text = "Status: Claiming..."
            StatusLabel.TextColor3 = Color3.fromRGB(255, 220, 50)
            local ok = claimAll()
            if ok then
                StatusLabel.Text = "Status: Claimed!"
                StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 150)
                LastLabel.Text = "Last Claim: " .. os.date("%H:%M:%S")
            else
                StatusLabel.Text = "Status: Failed - retrying..."
                StatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
                task.wait(30)
                claimAll()
            end
        end
    end
end)

