    btn.TextSize = 11
    btn.BorderSizePixel = 0
    Instance.new("UICorner",btn).CornerRadius = UDim.new(0,7)
    local on = isOn
    btn.MouseButton1Click:Connect(function()
        on = not on
        btn.BackgroundColor3 = on and Color3.fromRGB(120,60,255) or Color3.fromRGB(40,40,58)
        onChange(on)
