local function makeDelayRow(parent,lbl,def,onChange)
    local row = Instance.new("Frame",parent)
    row.Size = UDim2.new(1,0,0,34)
    row.BackgroundColor3 = Color3.fromRGB(25,25,38)
    row.BorderSizePixel = 0
    row.LayoutOrder = nextOrder()
    Instance.new("UICorner",row).CornerRadius = UDim.new(0,9)
    local ll = Instance.new("TextLabel",row)
    ll.Size = UDim2.new(0.6,0,1,0)
    ll.Position = UDim2.new(0,8,0,0)
    ll.BackgroundTransparency = 1
    ll.Text = lbl
    ll.TextColor3 = Color3.fromRGB(200,200,210)
    ll.Font = Enum.Font.Gotham
    ll.TextSize = 11
    ll.TextXAlignment = Enum.TextXAlignment.Left
    local box = Instance.new("TextBox",row)
    box.Size = UDim2.new(0.3,0,0,24)
    box.Position = UDim2.new(0.67,0,0.5,-12)
    box.BackgroundColor3 = Color3.fromRGB(40,40,60)
    box.Text = tostring(def)
    box.TextColor3 = Color3.fromRGB(255,255,255)
    box.Font = Enum.Font.GothamBold
    box.TextSize = 12
    box.BorderSizePixel = 0
    box.ClearTextOnFocus = false
    Instance.new("UICorner",box).CornerRadius = UDim.new(0,7)
    box.FocusLost:Connect(function()
        local v = tonumber(box.Text)
        if v then onChange(v) else box.Text = tostring(def) end
    end)
end

