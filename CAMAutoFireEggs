local function setRunningState(state)
    running = state
    if running then
        runId += 1
        btn.BackgroundColor3 = Color3.fromRGB(160, 30, 10)
        btn.Text = "⏹ Stop"
        statusLbl.Text = "Starting..."
        task.spawn(function() startCollecting(statusLbl) end)
    else
        btn.BackgroundColor3 = Color3.fromRGB(200, 80, 20)
        btn.Text = "▶ Start"
        statusLbl.Text = "Stopping..."
    end
    saveSettings()
end

