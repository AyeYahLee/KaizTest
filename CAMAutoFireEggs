local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local LP = Players.LocalPlayer

local DataPullFunc = RS.CommonLibrary.Tool.RemoteManager.Funcs.DataPullFunc
local AreaPickUp = workspace:WaitForChild("AreaPickUp")

local FIRE_EGG_TMPL = 201
local COLLECT_DELAY = 0.2
local LOOP_DELAY = 2
local TP_OFFSET = Vector3.new(0, 3, 0)

local running = false
local runId = 0
local savedPos = nil  -- saved return position

-- ── Helpers ───────────────────────────────────────────────────────────────────
local function teleportTo(pos)
    local char = LP.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    root.CFrame = CFrame.new(pos + TP_OFFSET)
    task.wait(0.1)
end

local function getFireEggs()
    local eggs = {}
    for _, part in ipairs(AreaPickUp:GetChildren()) do
        if part:IsA("BasePart") then
            local tmpl = part:GetAttribute("TmplId")
            if tmpl == FIRE_EGG_TMPL then
                local id = tonumber(part.Name)
                if id then
                    table.insert(eggs, {id = id, pos = part.Position, part = part})
                end
            end
        end
    end
    return eggs
end

local function collectEgg(egg, statusLbl)
    teleportTo(egg.pos)
    local ok = pcall(function()
        DataPullFunc:InvokeServer("AreaPickUpChannel", egg.id)
    end)
    if statusLbl then
        statusLbl.Text = (ok and "✅" or "❌").." ID: "..egg.id
    end
    task.wait(COLLECT_DELAY)
end

local function startCollecting(statusLbl)
    local myId = runId
    local total = 0
    while running and runId == myId do
        local eggs = getFireEggs()
        if #eggs == 0 then
            statusLbl.Text = "🔍 No fire eggs found\nWaiting..."
            task.wait(LOOP_DELAY)
            continue
        end
        for _, egg in ipairs(eggs) do
            if not running or runId ~= myId then break end
            collectEgg(egg, statusLbl)
            total += 1
        end
        if running and runId == myId then
            -- TP back to saved position after each loop
            if savedPos then
                statusLbl.Text = "🏠 Returning to saved pos..."
                teleportTo(savedPos)
            end
            statusLbl.Text = "♻️ Loop done! Total: "..total.."\nWaiting "..LOOP_DELAY.."s..."
            task.wait(LOOP_DELAY)
        end
    end
    statusLbl.Text = "Stopped. Total collected: "..total
end

