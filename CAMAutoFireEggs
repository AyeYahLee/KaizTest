local COLLECT_DELAY = 0.2
local LOOP_DELAY = 2
local TP_OFFSET = Vector3.new(0, 3, 0)

local running = false
local runId = 0
local savedPos = nil  -- saved return position
local MIN_EGGS = 4  -- minimum eggs before starting a collect run

-- ── Save / Load (survives rejoins, since writefile persists to disk) ───────────
local SETTINGS_FILE = "AutoFireEgg_NoxarSave.json"

local function saveSettings()
    if not writefile then return end

    local idsList = {}
    for id in pairs(selectedEggIds) do table.insert(idsList, id) end

    local data = {
        selectedEggIds = idsList,
        loopDelay = LOOP_DELAY,
        minEggs = MIN_EGGS,
        running = running,
        savedPos = savedPos and {savedPos.X, savedPos.Y, savedPos.Z} or nil,
    }

    pcall(function()
        writefile(SETTINGS_FILE, HttpService:JSONEncode(data))
    end)
end

local function loadSettings()
    if not (isfile and readfile and isfile(SETTINGS_FILE)) then return end

    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(SETTINGS_FILE))
    end)
    if not (ok and data) then return end

    if data.selectedEggIds and #data.selectedEggIds > 0 then
        local newSet = {}
        for _, id in ipairs(data.selectedEggIds) do
            if tonumber(id) then newSet[tonumber(id)] = true end
        end
        if next(newSet) then selectedEggIds = newSet end
    end

    LOOP_DELAY = tonumber(data.loopDelay) or LOOP_DELAY
    MIN_EGGS = tonumber(data.minEggs) or MIN_EGGS
    running = data.running or false

    if data.savedPos and #data.savedPos == 3 then
        savedPos = Vector3.new(data.savedPos[1], data.savedPos[2], data.savedPos[3])
    end
end

loadSettings()

-- ── Helpers ───────────────────────────────────────────────────────────────────
local function teleportTo(pos)
    local char = LP.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    root.CFrame = CFrame.new(pos + TP_OFFSET)
    task.wait(0.1)
end

local function getSelectedEggs()
    local eggs = {}
    for _, part in ipairs(AreaPickUp:GetChildren()) do
        if part:IsA("BasePart") then
            local tmpl = part:GetAttribute("TmplId")
            if tmpl and selectedEggIds[tmpl] then
                local id = tonumber(part.Name)
                if id then
                    table.insert(eggs, {id = id, pos = part.Position, part = part})
                end
            end
        end
    end
    return eggs
end

-- Scans every pickup currently in AreaPickUp and counts them by TmplId,
-- regardless of what's currently selected -- this is how you discover
-- what egg IDs exist nearby before typing them into the ID box.
local function scanEggTypes()
    local counts = {}
    for _, part in ipairs(AreaPickUp:GetChildren()) do
        if part:IsA("BasePart") then
            local tmpl = part:GetAttribute("TmplId")
            if tmpl then
                counts[tmpl] = (counts[tmpl] or 0) + 1
            end
        end
    end
    local sortedIds = {}
    for tmpl in pairs(counts) do table.insert(sortedIds, tmpl) end
    table.sort(sortedIds)
    return counts, sortedIds
end

local function collectEgg(egg, statusLbl)
    teleportTo(egg.pos)
    local ok = pcall(function()
        DataPullFunc:InvokeServer("AreaPickUpChannel", egg.id)
    end)
    if statusLbl then
        statusLbl.Text = (ok and "✅" or "❌").." ID: "..egg.id
    end
    task.wait(COLLECT_DELAY)
end

local function returnToSaved(statusLbl)
    if not savedPos then return end

    local char = LP.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- Don't teleport if we're already at the saved position
    if (root.Position - savedPos).Magnitude <= 5 then
        return
    end

    statusLbl.Text = "🏠 Returning to saved pos..."
    teleportTo(savedPos)
end

local function startCollecting(statusLbl)
    local myId = runId
    local total = 0
    while running and runId == myId do
        local eggs = getSelectedEggs()

        if #eggs < MIN_EGGS then
            -- Not enough eggs yet — return to saved pos and wait
            returnToSaved(statusLbl)
            statusLbl.Text = "⏳ "..#eggs.."/"..MIN_EGGS.." eggs...\nWaiting for more..."
            task.wait(LOOP_DELAY)
            continue
        end

        -- Enough eggs — go collect them all
        for _, egg in ipairs(eggs) do
            if not running or runId ~= myId then break end
            collectEgg(egg, statusLbl)
            total += 1
        end

        if running and runId == myId then
            -- Always return after collecting
            returnToSaved(statusLbl)
            statusLbl.Text = "♻️ Loop done! Total: "..total.."\nWaiting "..LOOP_DELAY.."s..."
            task.wait(LOOP_DELAY)
        end
    end
    -- Return to saved pos when stopped too
    returnToSaved(statusLbl)
    statusLbl.Text = "Stopped. Total collected: "..total
end

