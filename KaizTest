local function parseValue(str)
    local suffixes = { K = 1e3, M = 1e6, B = 1e9, T = 1e12, Q = 1e15 }
    local num, suffix = str:match("^([%d%.]+)([A-Za-z]*)")
    if not num then return 0 end
    num = tonumber(num) or 0
    if suffixes[suffix:upper()] then
        return num * suffixes[suffix:upper()]
    end
    return num
end

local function getPromptPosition(prompt)
    if prompt.Parent then
        if prompt.Parent:IsA("BasePart") then return prompt.Parent.Position
        elseif prompt.Parent:IsA("Model") and prompt.Parent.PrimaryPart then return prompt.Parent.PrimaryPart.Position
        elseif prompt.Parent:IsA("Attachment") then return prompt.Parent.WorldPosition end
    end
    return nil
end

local function FireNearestPrompt()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    local hrp = char.HumanoidRootPart
    local nearestPrompt, shortestDist = nil, 15 
    
    for _, prompt in ipairs(workspace:GetDescendants()) do
        if prompt:IsA("ProximityPrompt") then
            local promptPos = getPromptPosition(prompt)
            if promptPos and (promptPos - hrp.Position).Magnitude <= shortestDist then
                shortestDist = (promptPos - hrp.Position).Magnitude
                nearestPrompt = prompt
            end
        end
    end
    
    if nearestPrompt then
        local burstCount = tonumber(getgenv().InputBurst) or 1
        for i = 1, burstCount do
            task.spawn(function()
                fireproximityprompt(nearestPrompt)
            end)
        end
    end
end

