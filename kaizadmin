    local results = ""
    for _, item in pairs(player.Backpack:GetChildren()) do
        if item.Name == "Bat" then continue end
        results = results .. "\n=== " .. item.Name .. " ===\n"
        results = results .. "ToolTip: " .. tostring(item.ToolTip) .. "\n"
        results = results .. "DetectedValue: " .. tostring(getItemValue(item)) .. "\n"
        for _, desc in ipairs(item:GetDescendants()) do
            if desc:IsA("TextLabel") or desc:IsA("StringValue") or desc:IsA("NumberValue") or desc:IsA("IntValue") then
                local val = desc:IsA("TextLabel") and desc.Text or tostring(desc.Value)
                results = results .. desc.ClassName .. " @ " .. desc.Name .. " = " .. val .. "\n"
            end
        end
    end

    local debugLabel = Instance.new("TextLabel")
    debugLabel.Size = UDim2.new(0.9, 0, 0.7, 0)
    debugLabel.Position = UDim2.new(0.05, 0, 0.15, 0)
    debugLabel.BackgroundColor3 = Color3.fromRGB(10, 10, 20)
    debugLabel.TextColor3 = Color3.fromRGB(255, 255, 100)
    debugLabel.Font = Enum.Font.Code
    debugLabel.TextSize = 11
    debugLabel.TextWrapped = true
    debugLabel.TextXAlignment = Enum.TextXAlignment.Left
    debugLabel.TextYAlignment = Enum.TextYAlignment.Top
    debugLabel.Text = results == "" and "BACKPACK IS EMPTY" or results
    debugLabel.ZIndex = 999
    debugLabel.Parent = ScreenGui

    debugLabel.MouseButton1Click:Connect(function() debugLabel:Destroy() end)
    Instance.new("UICorner", debugLabel).CornerRadius = UDim.new(0, 10)
end)
