AutoTab:AddToggle("Autosell", false, function(state)
    getgenv().Selling = state
    if state then
        task.spawn(function()
            -- Cache remote once per session, not per cycle
            local sellRemote = game:GetService("ReplicatedStorage").Shared.Classes.RemoteFunction.Remotes.EntityShared_SellEntity
            while getgenv().Selling do
                local char = player.Character
                if not char then task.wait(0.05) continue end

                local backpack = player.Backpack
                if backpack then
                    local soldCount = 0
                    local maxP = getgenv().MaxPrice or 0
                    local items = backpack:GetChildren()
                    local toSell = {}
                    for _, item in ipairs(items) do
                        if not getgenv().Selling then break end -- stop mid-scan instantly on toggle off
                        if not isPetUUID(item.Name) then continue end
                        if not item:IsA("Tool") then continue end
                        local val = 0
                        pcall(function()
                            local text = item.Handle.ObjectInfo.Value.ValueLabel.Text
                            val = parseValue(text)
                        end)
                        if val == 0 then
                            pcall(function()
                                for _, desc in ipairs(item:GetDescendants()) do
                                    if desc:IsA("TextLabel") and desc.Name == "ValueLabel" then
                                        local v = parseValue(desc.Text)
                                        if v > 0 then val = v break end
                                    end
                                end
                            end)
                        end
                        if maxP == 0 or val <= maxP then
                            table.insert(toSell, item.Name)
                        end
                    end
                    soldCount = #toSell
                    for _, n in ipairs(toSell) do
                        if not getgenv().Selling then break end -- stop mid-sell instantly on toggle off
                        pcall(function() sellRemote:InvokeServer(n) end)
                    end
                    if soldCount > 0 then
                        sellStatus.Text = "💰 Sold " .. soldCount .. " pet(s)"
                        sellStatus.TextColor3 = Color3.fromRGB(100, 220, 100)
                    else
                        sellStatus.Text = "✅ Idle — 0 under " .. tostring(maxP)
                        sellStatus.TextColor3 = Color3.fromRGB(180, 180, 180)
                    end
                end

                task.wait(0.05)
            end
            sellStatus.Text = "⏹ Autosell stopped"
            sellStatus.TextColor3 = Color3.fromRGB(180, 180, 180)
        end)
    else
        sellStatus.Text = "⏹ Autosell stopped"
        sellStatus.TextColor3 = Color3.fromRGB(180, 180, 180)
