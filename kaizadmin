local function updateGiftFilterFromWhitelist()
    local selected = {}
    for name, v in pairs(whitelistSelected) do
        if v then table.insert(selected, name) end
    end
    if #selected == 0 then
        getgenv().GiftFilter = "ALL"
        _giftFilterInput.Text = "ALL"
    else
        local joined = table.concat(selected, ",")
        getgenv().GiftFilter = joined
        _giftFilterInput.Text = joined
    end
end

local function rebuildWhitelistGrid()
    for _, b in pairs(wlBtns) do pcall(function() b:Destroy() end) end
    wlBtns = {}
    local seen = {}
    local bp = player:FindFirstChild("Backpack")
    if not bp then return end
    for _, item in ipairs(bp:GetChildren()) do
        if item:IsA("Tool") then
            local n = ""
            pcall(function() n = item.ToolTip or "" end)
            n = n:gsub("<[^>]+>", ""):match("^%s*(.-)%s*$")
            if n ~= "" and not seen[n] then
                seen[n] = true
                local btn = Instance.new("TextButton")
                btn.Size = UDim2.new(0, 120, 0, 30)
                btn.BackgroundColor3 = whitelistSelected[n]
                    and Color3.fromRGB(90, 200, 90)
                    or  Color3.fromRGB(45, 45, 58)
                btn.BorderSizePixel = 0
                btn.Text = n:sub(1, 22)
                btn.TextColor3 = Color3.new(1,1,1)
                btn.Font = Enum.Font.Gotham
                btn.TextSize = 10
                btn.Parent = wlGrid
                Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
                local petName = n
                btn.MouseButton1Click:Connect(function()
                    whitelistSelected[petName] = not whitelistSelected[petName]
                    btn.BackgroundColor3 = whitelistSelected[petName]
                        and Color3.fromRGB(90, 200, 90)
                        or  Color3.fromRGB(45, 45, 58)
                    updateGiftFilterFromWhitelist()
                end)
                table.insert(wlBtns, btn)
            end
        end
    end
    -- Resize frame to fit grid
    task.defer(function()
        local gridH = wlLayout.AbsoluteContentSize.Y + 12
        wlGrid.Size = UDim2.new(1, 0, 0, gridH)
        wlGrid.Position = UDim2.new(0, 0, 0, 40)
        wlFrame.Size = UDim2.new(1, 0, 0, gridH + 46)
    end)
end

