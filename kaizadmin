MiscTab:AddToggle("✈️ Fly", false, function(state)
    getgenv().FlyEnabled = state
    if state then
        local char = player.Character or player.CharacterAdded:Wait()
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if not hrp or not hum then
            getgenv().FlyEnabled = false
            return
        end

        _flyBodyVel = Instance.new("BodyVelocity")
        _flyBodyVel.Velocity = Vector3.zero
        _flyBodyVel.MaxForce = Vector3.new(1e6, 1e6, 1e6)
        _flyBodyVel.Parent = hrp

        _flyBodyGyro = Instance.new("BodyGyro")
        _flyBodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
        _flyBodyGyro.P = 1e4
        _flyBodyGyro.CFrame = hrp.CFrame
        _flyBodyGyro.Parent = hrp

        hum.PlatformStand = true

        _flyConn = game:GetService("RunService").Heartbeat:Connect(function()
            if not getgenv().FlyEnabled then
                hum.PlatformStand = false
                stopFly()
                return
            end

            local speed = getgenv().FlySpeed or 50
            local cam = workspace.CurrentCamera
            local cf = cam.CFrame

            -- On mobile, MoveDirection is world-space from the thumbstick.
            -- We project it onto the camera axes so moving forward goes where you look.
            local md = hum.MoveDirection

            -- Camera-relative right and flat-forward (ignore vertical tilt for movement)
            local camRight   = cf.RightVector
            local camForward = Vector3.new(cf.LookVector.X, 0, cf.LookVector.Z)
            if camForward.Magnitude > 0.001 then
                camForward = camForward.Unit
            end
            -- camRight flattened too so strafing stays horizontal
            local camRightFlat = Vector3.new(camRight.X, 0, camRight.Z)
            if camRightFlat.Magnitude > 0.001 then
                camRightFlat = camRightFlat.Unit
            end

            local vel = Vector3.zero
            if md.Magnitude > 0.01 then
                -- Use full camera LookVector (includes vertical tilt) for forward movement
                -- so pointing camera up/down actually moves you up/down
                local fullForward = cf.LookVector
                local fwdAmt   = camForward:Dot(md)   -- how much thumbstick is pushing forward
                local rightAmt = camRightFlat:Dot(md)  -- how much thumbstick is pushing right

                -- Scale the full (tilted) forward by fwdAmt so vertical movement
                -- is proportional to camera pitch × how far forward stick is pushed
                local moveVec = fullForward * fwdAmt + camRightFlat * rightAmt
                if moveVec.Magnitude > 0.001 then
                    -- Multiply by 50 to match inf yield's feel: their "10" = ~500 studs/s internally
                    vel = moveVec.Unit * (speed * 50)
                end
            end

            _flyBodyVel.Velocity = vel

            -- Keep gyro flat so character body doesn't tilt with the camera
            local flatLook = Vector3.new(cf.LookVector.X, 0, cf.LookVector.Z)
            if flatLook.Magnitude > 0.001 then
                _flyBodyGyro.CFrame = CFrame.new(Vector3.zero, flatLook)
            end
        end)

        player.CharacterRemoving:Connect(stopFly)

    else
        local char = player.Character
        local hum = char and char:FindFirstChild("Humanoid")
        if hum then hum.PlatformStand = false end
        stopFly()
    end
end)

