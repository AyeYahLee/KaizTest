local function getBlocks(filter)
    local found = {}
    local backpack = player:FindFirstChild("Backpack")
    if not backpack then return found end
    for _, obj in ipairs(backpack:GetChildren()) do
        if obj:IsA("Tool") then
            local tip = ""
            pcall(function() tip = obj.ToolTip or "" end)
            -- Strip HTML/rich text tags so we get the plain name
            local plainTip = tip:gsub("<[^>]+>", ""):match("^%s*(.-)%s*$")
            local tipLower = plainTip:lower()
            -- Always require "block" in the tooltip so pets are never included
            if not tipLower:find("block", 1, true) then continue end
            local filterLower = filter:lower()
            if filterLower == "all" or tipLower:find(filterLower, 1, true) then
                table.insert(found, { uuid = obj.Name, label = plainTip ~= "" and plainTip or obj.Name })
            end
        end
    end
    return found
end

