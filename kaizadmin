-- ── Auto-load on startup ────────────────────────────────────────────────
-- Runs once at script start; uses task.defer so GUI finishes building first.
-- No loop, no connection kept alive — fires once and exits.
task.defer(function()
    local ok, autoName = pcall(readfile, AUTO_LOAD_KEY)
    if not ok or not autoName or autoName:match("^%s*$") then return end
    autoName = autoName:match("^%s*(.-)%s*$")
    local ok2, src = pcall(readfile, cfgPath(autoName))
    if not ok2 or not src then return end
    pcall(function()
        applyConfig(parseJSON(src))
        cfgStatus.Text = "⚡ Auto-loaded: " .. autoName
        cfgStatus.TextColor3 = Color3.fromRGB(180, 130, 255)
    end)
end)
