    stopBlockBtn2.MouseButton1Click:Connect(function()
        stopBlockGift = true
        blockGiftStatus.Text = "🛑 Stopping..."
        blockGiftStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
    end)

    giftBlockBtn.MouseButton1Click:Connect(function()
        local targetName = (giftUsernameInput.Text or ""):match("^%s*(.-)%s*$")
        if targetName == "" then
            blockGiftStatus.Text = "❌ No player entered"
            blockGiftStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
            return
        end
        local target = Players:FindFirstChild(targetName)
        if not target then
            blockGiftStatus.Text = "❌ Player not in server"
            blockGiftStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
            return
        end

        stopBlockGift = true
        while isBlockGifting do task.wait(0.1) end
        stopBlockGift = false

        task.spawn(function()
            isBlockGifting = true
            local filter = (_blockGiftFilterInput.Text or "ALL"):match("^%s*(.-)%s*$"):lower()
            if filter == "" then filter = "all" end
            local totalGifted = 0

            while not stopBlockGift do
                local blocks = {}
                local backpack = player:FindFirstChild("Backpack")
                if backpack then
                    for _, obj in ipairs(backpack:GetChildren()) do
                        if obj:IsA("Tool") then
                            local tip = ""
                            pcall(function() tip = obj.ToolTip or "" end)
                            local plainTip = tip:gsub("<[^>]+>", ""):lower()
                            if plainTip:find("block", 1, true) then
                                if filter == "all" or plainTip:find(filter, 1, true) then
                                    local guid = obj:GetAttribute("GUID") or obj:GetAttribute("LuckyBlockGUID") or obj.Name
                                    table.insert(blocks, {uuid = tostring(guid), label = tip:gsub("<[^>]+>", ""):match("^%s*(.-)%s*$") or obj.Name})
                                end
                            end
                        end
                    end
                end

                -- Apply SPECIFIC limit
                if blockGiftMode == "SPECIFIC" then
                    local limit = blockGiftAmount
                    local trimmed = {}
                    for i = 1, math.min(limit, #blocks) do
                        table.insert(trimmed, blocks[i])
                    end
                    blocks = trimmed
                end

                if #blocks == 0 then
                    if totalGifted == 0 then
                        blockGiftStatus.Text = "❌ No matching blocks found"
                        blockGiftStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
                    else
                        blockGiftStatus.Text = "✅ Done! Gifted " .. totalGifted .. " block(s)"
                        blockGiftStatus.TextColor3 = Color3.fromRGB(100, 220, 100)
                    end
                    break
                end

                for i, data in ipairs(blocks) do
                    if stopBlockGift then break end
                    pcall(function()
                        Remotes.GiftingShared_RequestGifting:FireServer(target, "LuckyBlock", data.uuid)
                    end)
                    totalGifted = totalGifted + 1
                    blockGiftStatus.Text = "🎁 Gifted " .. totalGifted .. " — " .. data.label
                    blockGiftStatus.TextColor3 = Color3.fromRGB(100, 220, 100)
                    task.wait(0.18)
                end

                -- If SPECIFIC mode, stop after one pass
                if blockGiftMode == "SPECIFIC" then break end
            end

            if stopBlockGift and totalGifted > 0 then
                blockGiftStatus.Text = "🛑 Stopped — " .. totalGifted .. " gifted"
                blockGiftStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
            end
            isBlockGifting = false
        end)
    end)
