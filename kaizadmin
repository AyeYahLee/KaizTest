-- Stored outside so rapid toggles can't stack connections
local _sellAddedConn, _sellRemovedConn

_guiToggles["Selling"] = AutoTab:AddToggle("Autosell", false, function(state)
    getgenv().Selling = state
    -- Disconnect any existing connections before starting fresh
    if _sellAddedConn then _sellAddedConn:Disconnect(); _sellAddedConn = nil end
    if _sellRemovedConn then _sellRemovedConn:Disconnect(); _sellRemovedConn = nil end
    if state then
        task.spawn(function()
            -- Cache remote once per session, not per cycle
            local sellRemote = game:GetService("ReplicatedStorage").Shared.Classes.RemoteFunction.Remotes.EntityShared_SellEntity
            local backpack = player.Backpack
            local scanPending = false

            local function doSell()
                if not getgenv().Selling then return end
                local bp = player.Backpack
                if not bp then return end
                local maxP = getgenv().MaxPrice or 0
                if maxP == 0 then
                    sellStatus.Text = "⚠️ Set a Max Price to sell"
                    sellStatus.TextColor3 = Color3.fromRGB(255, 160, 50)
                    scanPending = false
                    return
                end
                local toSell = {}
                for _, item in ipairs(bp:GetChildren()) do
                    if not getgenv().Selling then break end
                    if not isPetUUID(item.Name) then continue end
                    if not item:IsA("Tool") then continue end
                    -- Skip lucky blocks (ancient blocks etc) — not sellable
                    local tip = ""
                    pcall(function() tip = item.ToolTip or "" end)
                    if tip:lower():find("block") then continue end
                    local val = 0
                    pcall(function()
                        local text = item.Handle.ObjectInfo.Value.ValueLabel.Text
                        val = parseValue(text)
                    end)
                    if val == 0 then
                        pcall(function()
                            for _, desc in ipairs(item:GetDescendants()) do
                                if desc:IsA("TextLabel") and desc.Name == "ValueLabel" then
                                    local v = parseValue(desc.Text)
                                    if v > 0 then val = v break end
                                end
                            end
                        end)
                    end
                    -- maxP == 0 means no price set, skip selling entirely
                    -- only sell if a price is set AND the pet's value is at or below it
                    if maxP > 0 and val <= maxP then
                        table.insert(toSell, item.Name)
                    end
                end
                local totalToSell = #toSell
                if totalToSell > 0 then
                    sellStatus.Text = "💰 Selling " .. totalToSell .. " pet(s)..."
                    sellStatus.TextColor3 = Color3.fromRGB(255, 200, 50)
                    -- Fire all sell remotes simultaneously — each in its own thread
                    for _, n in ipairs(toSell) do
                        task.spawn(function()
                            pcall(function() sellRemote:InvokeServer(n) end)
                        end)
                    end
                    sellStatus.Text = "✅ Done — sold " .. totalToSell
                    sellStatus.TextColor3 = Color3.fromRGB(100, 220, 100)
                else
                    sellStatus.Text = "✅ Idle — nothing to sell"
                    sellStatus.TextColor3 = Color3.fromRGB(180, 180, 180)
                end
                scanPending = false
            end

            local function queueSell()
                if scanPending then return end
                scanPending = true
                -- Small delay so rapid adds (farming burst) batch into one scan
                task.delay(0.5, doSell)
            end

            if backpack then
                _sellAddedConn   = backpack.ChildAdded:Connect(queueSell)
                _sellRemovedConn = backpack.ChildRemoved:Connect(queueSell)
            end

            -- Run one initial scan in case there's already stuff to sell
            doSell()

            -- Wait loop: just sleeps until toggled off, no work done here
            while getgenv().Selling do
                task.wait(1)
            end

            if _sellAddedConn   then _sellAddedConn:Disconnect();   _sellAddedConn = nil end
            if _sellRemovedConn then _sellRemovedConn:Disconnect(); _sellRemovedConn = nil end
            sellStatus.Text = "⏹ Autosell stopped"
            sellStatus.TextColor3 = Color3.fromRGB(180, 180, 180)
        end)
    else
        sellStatus.Text = "⏹ Autosell stopped"
        sellStatus.TextColor3 = Color3.fromRGB(180, 180, 180)
    end
end)

