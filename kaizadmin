-- Set auto-load — writes profile name to a tiny sentinel file
ConfigTab:AddButton("⚡ Set as Auto-Load", Color3.fromRGB(120, 80, 200), function()
    local name = profileNameInput.Text:match("^%s*(.-)%s*$")
    if name == "" then
        cfgStatus.Text = "❌ Enter a profile name first"
        cfgStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end
    -- Verify the profile actually exists before setting auto-load
    local exists = pcall(readfile, cfgPath(name))
    if not exists then
        cfgStatus.Text = "❌ Save the profile first"
        cfgStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end
    pcall(writefile, AUTO_LOAD_KEY, name)
    cfgStatus.Text = "⚡ Auto-load set: " .. name
    cfgStatus.TextColor3 = Color3.fromRGB(180, 130, 255)
end)

-- Clear auto-load sentinel
ConfigTab:AddButton("✕ Clear Auto-Load", Color3.fromRGB(80, 80, 100), function()
    pcall(delfile, AUTO_LOAD_KEY)
    cfgStatus.Text = "✕ Auto-load cleared"
    cfgStatus.TextColor3 = Color3.fromRGB(180, 180, 180)
end)

-- ── Auto-load on startup ────────────────────────────────────────────────
-- Runs once at script start; uses task.defer so GUI finishes building first.
-- No loop, no connection kept alive — fires once and exits.
task.defer(function()
    local ok, autoName = pcall(readfile, AUTO_LOAD_KEY)
    if not ok or not autoName or autoName:match("^%s*$") then return end
    autoName = autoName:match("^%s*(.-)%s*$")
    local ok2, src = pcall(readfile, cfgPath(autoName))
    if not ok2 or not src then return end
    pcall(function()
        applyConfig(parseJSON(src))
        cfgStatus.Text = "⚡ Auto-loaded: " .. autoName
        cfgStatus.TextColor3 = Color3.fromRGB(180, 130, 255)
    end)
end)
