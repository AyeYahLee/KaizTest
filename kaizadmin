local function parseValue(str)
    if not str then return 0 end
    str = tostring(str):gsub(",",""):match("^%s*(.-)%s*$")
    -- Strip HTML tags
    str = str:gsub("<[^>]+>", "")
    str = str:match("^%s*(.-)%s*$")
    local suffixes = {k=1e3,m=1e6,b=1e9,t=1e12,q=1e15}
    local num, suffix = str:lower():match("^([%d%.]+)([a-z]*)")
    if not num then return 0 end
    num = tonumber(num) or 0
    return num * (suffixes[suffix] or 1)
end

local uuidPattern = "%x%x%x%x%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%-%x%x%x%x%x%x%x%x%x%x%x%x"

local function isPetUUID(name)
    return string.match(name, uuidPattern) ~= nil
end

local function getItemValue(item)
    -- Single-pass over descendants (avoids 3x full tree walks per item)
    local fallbackLabel = nil
    for _, desc in ipairs(item:GetDescendants()) do
        if desc:IsA("NumberValue") or desc:IsA("IntValue") then
            local n = desc.Name:lower()
            if (n == "value" or n == "worth" or n == "price" or n == "cash") and desc.Value > 0 then
                return desc.Value
            end
        elseif desc:IsA("TextLabel") then
            if desc.Name == "ValueLabel" then
                local val = parseValue(desc.Text)
                if val > 0 then return val end
            elseif not fallbackLabel then
                fallbackLabel = desc
            end
        end
    end
    if fallbackLabel then
        local val = parseValue(fallbackLabel.Text)
        if val > 0 then return val end
    end
    -- Item attributes
    for _, attrName in ipairs({"Value","Worth","Price","Cash","value","worth"}) do
        local attr = item:GetAttribute(attrName)
        if attr and type(attr) == "number" and attr > 0 then return attr end
    end
    return -1 -- unknown; sell anyway if maxP is 0 (sell all mode)
end

local function getPromptPosition(prompt)
    if prompt.Parent then
        if prompt.Parent:IsA("BasePart") then return prompt.Parent.Position
        elseif prompt.Parent:IsA("Model") and prompt.Parent.PrimaryPart then return prompt.Parent.PrimaryPart.Position
        elseif prompt.Parent:IsA("Attachment") then return prompt.Parent.WorldPosition end
    end
    return nil
end

local function FireNearestPrompt()
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    local nearestPrompt, shortestDist = nil, 15
    -- Search only within the chosen zone (or fallback to workspace) to avoid
    -- walking the entire game tree — huge CPU saving on large maps
    local searchRoot = (getgenv().ChosenZone) or workspace
    for _, prompt in ipairs(searchRoot:GetDescendants()) do
        if prompt:IsA("ProximityPrompt") then
            local pos = getPromptPosition(prompt)
            if pos and (pos - hrp.Position).Magnitude <= shortestDist then
                shortestDist = (pos - hrp.Position).Magnitude
                nearestPrompt = prompt
            end
        end
    end
    if nearestPrompt then
        -- Fire inline: no need to spawn a new thread per burst shot
        local burst = tonumber(getgenv().InputBurst) or 1
        for i = 1, burst do
            pcall(fireproximityprompt, nearestPrompt)
        end
    end
end

local function getPetName(obj)
    local tooltip = ""
    pcall(function() tooltip = obj.ToolTip or "" end)
    if tooltip ~= "" then
        local plain = tooltip:gsub("<[^>]+>", "")
        plain = plain:match("^%s*(.-)%s*$")
        if plain ~= "" then return plain end
    end
    local guid = obj:GetAttribute("EntityGUID")
    if guid then return guid end
    return "Unknown"
end

local function GetInventoryPets(filter)
    local found = {}
    local backpack = player:FindFirstChild("Backpack")
    if not backpack then return found end
    -- Support comma-separated whitelist e.g. "Rainbow Cat,Dark Matter Dog"
    local filters = {}
    if string.upper(filter) ~= "ALL" then
        for f in (filter .. ","):gmatch("([^,]+),") do
            table.insert(filters, f:match("^%s*(.-)%s*$"):lower())
        end
    end
    for _, obj in ipairs(backpack:GetChildren()) do
        if string.match(obj.Name, uuidPattern) then
            local petName = getPetName(obj)
            local matchesFilter = #filters == 0 -- ALL
            if not matchesFilter then
                for _, f in ipairs(filters) do
                    if string.find(string.lower(petName), f, 1, true) then
                        matchesFilter = true
                        break
                    end
                end
            end
            if matchesFilter then
                table.insert(found, {uuid = obj.Name, pet = petName})
            end
        end
    end
    return found
end

