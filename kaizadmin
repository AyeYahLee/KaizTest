    stopGiftBtn.Size = UDim2.new(0.35, 0, 1, 0)
    stopGiftBtn.BackgroundColor3 = Color3.fromRGB(160, 0, 0)
    stopGiftBtn.Text = "■ STOP"
    stopGiftBtn.Font = Enum.Font.GothamBold
    stopGiftBtn.TextSize = 12
    stopGiftBtn.TextColor3 = Color3.new(1,1,1)
    stopGiftBtn.BorderSizePixel = 0
    stopGiftBtn.Parent = giftRow
    Instance.new("UICorner", stopGiftBtn).CornerRadius = UDim.new(0, 6)

    stopGiftBtn.MouseButton1Click:Connect(function()
        getgenv().StopGift = true
        giftStatusLabel.Text = "🛑 Stopping..."
        giftStatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
    end)

    startGiftBtn.MouseButton1Click:Connect(function()
    getgenv().StopGift = false
    local username = getgenv().GiftTarget
    local filter = getgenv().GiftFilter or "ALL"

    if username == "" then
        giftStatusLabel.Text = "❌ No player entered"
        giftStatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end
    local target = Players:FindFirstChild(username)
    if not target then
        giftStatusLabel.Text = "❌ Player not in server"
        giftStatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end
    if target == player then
        giftStatusLabel.Text = "❌ Cannot gift yourself"
        giftStatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end

    giftStatusLabel.Text = "🔍 Scanning..."
    giftStatusLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
    task.wait(0.1)

    local pets = GetInventoryPets(filter)
    if #pets == 0 then
        giftStatusLabel.Text = "❌ No matching pets"
        giftStatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end

    if getAmountMode() == "SPECIFIC" then
        local limit = tonumber(getgenv().GiftAmount)
        if not limit or limit <= 0 then
            giftStatusLabel.Text = "❌ Invalid amount"
            giftStatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
            return
        end
        local trimmed = {}
        for i = 1, math.min(limit, #pets) do table.insert(trimmed, pets[i]) end
        pets = trimmed
    end

    task.spawn(function()
        giftStatusLabel.TextColor3 = Color3.fromRGB(100, 220, 100)
        for i, data in ipairs(pets) do
            if getgenv().StopGift then
                giftStatusLabel.Text = "🛑 Stopped at " .. i-1 .. "/" .. #pets
                giftStatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
                break
            end
            pcall(function()
                Remotes.GiftingShared_RequestGifting:FireServer(target, "Entity", data.uuid)
            end)
            giftStatusLabel.Text = "🎁 " .. i .. "/" .. #pets .. " — " .. data.pet
            task.wait(0.18)
        end
        if not getgenv().StopGift then
            giftStatusLabel.Text = "✅ Done! Gifted " .. #pets .. " pet(s)"
        end
    end)
end)

end



