-- ==========================================
-- CONFIG TAB
-- ==========================================
-- Uses writefile/readfile (executor API) to persist profiles.
-- Each profile is saved as a separate JSON-like file under a folder.
-- No connections are left open — all operations are one-shot, no loops,
-- no persistent threads. Zero memory leak surface.

local CONFIG_FOLDER = "KaizAdminHub"
local CONFIG_EXT    = ".cfg"
local AUTO_LOAD_KEY = CONFIG_FOLDER .. "/autoload.txt"

-- Ensure folder exists (pcall so it never throws)
pcall(function() makefolder(CONFIG_FOLDER) end)

-- ── Helpers ────────────────────────────────────────────────────────────
local function cfgPath(name)
    return CONFIG_FOLDER .. "/" .. tostring(name):gsub("[^%w_%-]", "_") .. CONFIG_EXT
end

-- Lightweight serialiser — stores only the getgenv() keys that we care about.
-- Does NOT walk the entire environment, so no runaway memory usage.
local SAVE_KEYS = {
    "Farming", "Selling", "PositionCycle", "AutoClaim", "AutoUpgrade",
    "AutoAcceptGift", "StopGift", "MaxPrice", "MinFarmValue", "InputBurst",
    "ClaimSlots", "UpgradeSlots", "GiftTarget", "GiftFilter", "GiftAmount",
    "ChosenZone",  -- saved as zone name string, restored on load
}

local function serializeValue(k, v)
    local t = type(v)
    if t == "boolean" then return (v and "true" or "false")
    elseif t == "number" then return tostring(v)
    elseif t == "string" then return '"' .. v:gsub('"', '\\"') .. '"'
    elseif t == "table" then
        -- Only handle flat arrays of numbers (slot lists)
        local parts = {}
        for _, n in ipairs(v) do
            if type(n) == "number" then
                parts[#parts+1] = tostring(n)
            end
        end
        return "[" .. table.concat(parts, ",") .. "]"
    elseif t == "userdata" or t == "Instance" then
        -- ChosenZone → store its name
        pcall(function()
            if v and v.Name then return end
        end)
        local ok, name = pcall(function() return v.Name end)
        return ok and ('"' .. tostring(name) .. '"') or '"Zone1"'
    end
    return "null"
end

local function buildJSON()
    local lines = {"{"}
    local count = 0
    for _, k in ipairs(SAVE_KEYS) do
        local v = getgenv()[k]
        if v ~= nil then
            count = count + 1
            lines[#lines+1] = '  "' .. k .. '": ' .. serializeValue(k, v) .. ","
        end
    end
    -- Remove trailing comma from last entry
    if count > 0 then
        lines[#lines] = lines[#lines]:sub(1, -2)
    end
    lines[#lines+1] = "}"
    return table.concat(lines, "\n")
end

-- Minimal JSON-ish parser for our own format (no external deps)
local function parseJSON(src)
    local data = {}
    -- Booleans
    for k, v in src:gmatch('"([%w_]+)"%s*:%s*(true)') do data[k] = true end
    for k, v in src:gmatch('"([%w_]+)"%s*:%s*(false)') do data[k] = false end
    -- Numbers
    for k, v in src:gmatch('"([%w_]+)"%s*:%s*(-?%d+%.?%d*)') do
        if data[k] == nil then data[k] = tonumber(v) end
    end
    -- Strings
    for k, v in src:gmatch('"([%w_]+)"%s*:%s*"(.-)"') do
        if data[k] == nil then data[k] = v end
    end
    -- Arrays of numbers
    for k, v in src:gmatch('"([%w_]+)"%s*:%s*%[([^%]]*)%]') do
        if data[k] == nil then
            local arr = {}
            for n in v:gmatch("%-?%d+%.?%d*") do
                arr[#arr+1] = tonumber(n)
            end
            data[k] = arr
        end
    end
    return data
end

local function applyConfig(data)
    for _, k in ipairs(SAVE_KEYS) do
        if data[k] ~= nil then
            if k == "ChosenZone" then
                -- Resolve zone name back to instance safely
                local zoneName = tostring(data[k])
                local zone = zonesFold:FindFirstChild(zoneName)
                if zone then
                    getgenv().ChosenZone = zone
                    -- Sync zone textbox: strip "Zone" prefix to get the number
                    local zoneNum = zoneName:match("^Zone(%d+)$")
                    if zoneNum and _guiTextboxes["ChosenZone"] then
                        _guiTextboxes["ChosenZone"].Text = zoneNum
                    end
                end
            else
                getgenv()[k] = data[k]
                -- Sync toggle GUI
                if _guiToggles[k] then
                    pcall(_guiToggles[k]._setState, data[k])
                end
                -- Sync textbox GUI
                if _guiTextboxes[k] then
                    _guiTextboxes[k].Text = tostring(data[k])
                end
            end
        end
    end
end

-- Returns sorted list of saved profile names (strips path + extension)
local function listProfiles()
    local names = {}
    pcall(function()
        for _, f in ipairs(listfiles(CONFIG_FOLDER)) do
            local name = f:match("([^/\\]+)" .. CONFIG_EXT .. "$")
            if name then names[#names+1] = name end
        end
    end)
    table.sort(names)
    return names
end

