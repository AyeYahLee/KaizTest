-- TP + CHIP COLLECT
local function tpAndCollect(obj, id)

    local targetCFrame

    if obj:IsA("BasePart") then
        targetCFrame = obj.CFrame

    elseif obj:IsA("Model") and obj.PrimaryPart then
        targetCFrame = obj.PrimaryPart.CFrame
    end

    if targetCFrame then

        -- TP CLOSE FOR TOUCH
        HumanoidRootPart.CFrame = targetCFrame + Vector3.new(0,1,0)

        task.wait(0.05)

        pcall(function()
            CollectRemote:FireServer({
                collectibleId = id
            })
        end)
    end
end

-- AUTO CHIP LOOP
task.spawn(function()

    local collected = {}

    while task.wait(0.1) do

        if not AutoChip then
            continue
        end

        for _, obj in ipairs(workspace:GetDescendants()) do

            local id = obj:GetAttribute("collectibleId")

            if not id then
                id = obj.Name
            end

            if id and tostring(id):find("GoldenChips") then

                if not collected[id] then

                    collected[id] = true

                    tpAndCollect(obj, id)

                    task.delay(5, function()
                        collected[id] = nil
                    end)
                end
            end
        end
    end
end)

-- AUTO SPIN LOOP
task.spawn(function()

    while task.wait(1) do

        if AutoSpin then

            pcall(function()

                local args = {
                    {
                        Function = "RequestExchangePurchase",
                        Args = {
                            false
                        }
                    }
                }

                SpinRemote:FireServer(unpack(args))

            end)
        end
    end
end)

