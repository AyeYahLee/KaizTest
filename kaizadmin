--// KAIZ GOLDEN CHIP FARM + TELEPORT
--// Teleports to spawned chips then instantly collects them

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CoreGui = game:GetService("CoreGui")

local LocalPlayer = Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()

local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")

-- REMOTE
local CollectRemote = ReplicatedStorage
    :WaitForChild("Packages")
    :WaitForChild("_Index")
    :WaitForChild("sleitnick_net@0.2.0")
    :WaitForChild("net")
    :WaitForChild("RE/CollectibleCollect")

local AutoFarm = false

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "KaizChipFarm"
gui.Parent = CoreGui

local frame = Instance.new("Frame")
frame.Parent = gui
frame.Size = UDim2.new(0,180,0,90)
frame.Position = UDim2.new(0,20,0.4,0)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.BorderSizePixel = 0
frame.Active = true
frame.Draggable = true

local title = Instance.new("TextLabel")
title.Parent = frame
title.Size = UDim2.new(1,0,0,30)
title.BackgroundTransparency = 1
title.Text = "KAIZ CHIP FARM"
title.TextScaled = true
title.Font = Enum.Font.GothamBold
title.TextColor3 = Color3.new(1,1,1)

local toggle = Instance.new("TextButton")
toggle.Parent = frame
toggle.Size = UDim2.new(0.8,0,0,35)
toggle.Position = UDim2.new(0.1,0,0.5,0)
toggle.BackgroundColor3 = Color3.fromRGB(170,0,0)
toggle.Text = "OFF"
toggle.TextScaled = true
toggle.Font = Enum.Font.GothamBold
toggle.TextColor3 = Color3.new(1,1,1)

toggle.MouseButton1Click:Connect(function()
    AutoFarm = not AutoFarm

    if AutoFarm then
        toggle.Text = "ON"
        toggle.BackgroundColor3 = Color3.fromRGB(0,170,0)
    else
        toggle.Text = "OFF"
        toggle.BackgroundColor3 = Color3.fromRGB(170,0,0)
    end
end)

-- TELEPORT + COLLECT
local function tpAndCollect(obj, id)

    -- teleport
    if obj:IsA("BasePart") then
        HumanoidRootPart.CFrame = obj.CFrame + Vector3.new(0,3,0)

    elseif obj:IsA("Model") and obj.PrimaryPart then
        HumanoidRootPart.CFrame = obj.PrimaryPart.CFrame + Vector3.new(0,3,0)
    end

    task.wait(0.1)

    -- collect
    pcall(function()
        CollectRemote:FireServer({
            collectibleId = id
        })
    end)
end

-- LOOP
task.spawn(function()
    while task.wait(0.1) do
        if AutoFarm then

            for _, obj in ipairs(workspace:GetDescendants()) do

                local id = obj:GetAttribute("collectibleId")

                -- attribute check
                if id and tostring(id):find("GoldenChips") then
                    tpAndCollect(obj, id)
                end

                -- fallback name check
                if tostring(obj.Name):find("GoldenChips") then
                    tpAndCollect(obj, obj.Name)
                end
            end

        end
    end
end)

print("KAIZ TP CHIP FARM LOADED")
