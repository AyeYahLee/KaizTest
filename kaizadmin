_guiToggles["Farming"] = AutoTab:AddToggle("Autofarm", false, function(state)
    getgenv().Farming = state
    if state then
        local sessionCount = 0
        farmStatus.Text = "🌾 Scanning... | Farmed: 0"
        farmStatus.TextColor3 = Color3.fromRGB(255, 200, 50)
        task.spawn(function()
            while getgenv().Farming do
                local char = player.Character
                if not char or not getgenv().ChosenZone then task.wait(1) continue end
                local objects = getgenv().ChosenZone:FindFirstChild("Objects")
                if objects then
                    for _, obj in pairs(objects:GetChildren()) do
                        if not getgenv().Farming then break end
                        -- Walk all descendants to find pet name (same as V3 - actually works)
                        local nameParts = {}
                        pcall(function()
                            for _, v in pairs(obj:GetDescendants()) do
                                if v:IsA("TextLabel") then
                                    local t = tostring(v.Text):lower()
                                    if t ~= "" then nameParts[#nameParts+1] = t end
                                elseif v:IsA("StringValue") then
                                    local t = tostring(v.Value):lower()
                                    if t ~= "" then nameParts[#nameParts+1] = t end
                                end
                            end
                        end)
                        local name = #nameParts > 0 and table.concat(nameParts, " ") or tostring(obj.Name):lower()

                        local detectedValue = 0
                        pcall(function()
                            local raw = name:match("(%d+%.?%d*[kmbtq])") or name:match("(%d+%.?%d*)")
                            if raw then
                                local num, suffix = raw:match("([%d%.]+)([kmbtq]?)")
                                num = tonumber(num) or 0
                                local multipliers = {k=1e3,m=1e6,b=1e9,t=1e12,q=1e15}
                                detectedValue = num * (multipliers[suffix] or 1)
                            end
                        end)

                        local celestialPet = name:find("tung tung tung sahur") or name:find("esok sekolah") or name:find("job job job sahur") or name:find("chillin chili")
                        local isRainbow = name:find("rainbow")
                        local isDarkMatter = name:find("darkmatter") or name:find("dark matter")
                        local isAncient = name:find("ancient")

                        local shouldFarm = false
                        if celestialPet and (isRainbow or isDarkMatter) then shouldFarm = true end
                        local celestialThresh = (getgenv().MinFarmValue and getgenv().MinFarmValue > 0) and getgenv().MinFarmValue or 1000000
                        if celestialPet and not isRainbow and not isDarkMatter and detectedValue >= celestialThresh then shouldFarm = true end
                        if isAncient and (isRainbow or isDarkMatter) then shouldFarm = true end
                        -- Fallback: farm any pet that meets the min value threshold if no specific variant matched
                        local minVal = getgenv().MinFarmValue or 0
                        if not shouldFarm and minVal > 0 and detectedValue >= minVal then shouldFarm = true end
                        if name:find("cosmic") then shouldFarm = false end
                        if name:find("radioactive") then shouldFarm = false end

                        if shouldFarm then
                            if obj:IsA("Model") and obj.PrimaryPart then
                                local burst = tonumber(getgenv().InputBurst) or 30

                                -- Step 1: TP on top of pet
                                char = player.Character
                                if not char or not char:FindFirstChild("HumanoidRootPart") then continue end
                                local hrp = char.HumanoidRootPart
                                local tpPos = obj.PrimaryPart.CFrame + Vector3.new(0, 3, 0)
                                hrp.CFrame = tpPos

                                -- Step 2: Lock position using BodyPosition so waves can't push you off
                                local anchor = Instance.new("BodyPosition")
                                anchor.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                                anchor.D = 1000
                                anchor.P = 100000
                                anchor.Position = tpPos.Position
                                anchor.Parent = hrp

                                -- Step 3: Wait for server to register position
                                task.wait(0.5)

                                -- Step 4: Fire once
                                local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
                                if prompt then
                                    for i = 1, burst do
                                        pcall(fireproximityprompt, prompt)
                                    end
                                end

                                -- Step 5: Wait 2s locked in place on the pet
                                task.wait(2)

                                -- Step 6: Unlock position before TPing
                                anchor:Destroy()

                                -- Step 7: TP to base
                                pcall(function()
                                    local freshHRP = player.Character.HumanoidRootPart
                                    freshHRP.CFrame = workspace.Bases[player.Name].Root.CFrame + Vector3.new(0, 3, 0)
                                end)

                                -- Step 8: Wait 1s at base for pets to arrive in backpack
                                task.wait(1)
                                sessionCount = sessionCount + 1
                                getgenv().FarmSessionCount = sessionCount
                                local displayName = name:gsub("<[^>]+>", ""):match("^%s*(.-)%s*$")
                                -- Reformat: move variant word to front and title-case
                                -- e.g. "job job job sahur rainbow variant" -> "Rainbow Job Job Job Sahur"
                                local variants = {"rainbow", "dark matter", "darkmatter", "golden", "gold", "shiny", "cosmic"}
                                local foundVariant = nil
                                local petNameOnly = displayName
                                for _, v in ipairs(variants) do
                                    if displayName:lower():find(v, 1, true) then
                                        foundVariant = v:gsub("^%l", string.upper)
                                        petNameOnly = displayName:lower():gsub(v, ""):gsub("variant", ""):match("^%s*(.-)%s*$")
                                        break
                                    end
                                end
                                -- Also strip trailing "variant" if no specific variant found
                                petNameOnly = petNameOnly:gsub("variant", ""):match("^%s*(.-)%s*$")
                                -- Title case the pet name
                                local titled = petNameOnly:gsub("(%a)([%w_']*)", function(a,b) return a:upper()..b end)
                                local shortName = (foundVariant and (foundVariant .. " ") or "") .. titled
                                shortName = shortName:sub(1, 30)
                                farmStatus.Text = "✅ Farmed: " .. sessionCount .. " | " .. shortName
                                farmStatus.TextColor3 = Color3.fromRGB(100, 220, 100)
                                pushHistory(shortName, sessionCount)
                            end
                        end
                    end
                end
                task.wait(1)
            end
        end)
    else
        farmStatus.Text = "⏹ Stopped | Session farmed: " .. (getgenv().FarmSessionCount or 0)
        farmStatus.TextColor3 = Color3.fromRGB(180, 180, 180)
    end
end)

