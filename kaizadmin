local profileListCollapsed = true

local function refreshProfileList()
    for _, c in pairs(profileListFrame:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end
    local profiles = listProfiles()
    if #profiles == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, 0, 0, 30)
        empty.BackgroundTransparency = 1
        empty.Text = "  No profiles saved yet"
        empty.TextColor3 = Color3.fromRGB(130, 130, 150)
        empty.Font = Enum.Font.Gotham
        empty.TextSize = 12
        empty.TextXAlignment = Enum.TextXAlignment.Left
        empty.Parent = profileListFrame
    else
        for _, name in ipairs(profiles) do
            local pb = Instance.new("TextButton")
            pb.Parent = profileListFrame
            pb.Size = UDim2.new(1, 0, 0, 36)
            pb.Text = "  " .. name
            pb.BackgroundColor3 = Color3.fromRGB(35, 35, 48)
            pb.TextColor3 = Color3.new(1, 1, 1)
            pb.TextXAlignment = Enum.TextXAlignment.Left
            pb.BorderSizePixel = 0
            pb.Font = Enum.Font.Gotham
            pb.TextSize = 13
            Instance.new("UICorner", pb).CornerRadius = UDim.new(0, 6)
            pb.MouseButton1Click:Connect(function()
                for _, b in pairs(profileListFrame:GetChildren()) do
                    if b:IsA("TextButton") then b.BackgroundColor3 = Color3.fromRGB(35, 35, 48) end
                end
                pb.BackgroundColor3 = Color3.fromRGB(0, 100, 180)
                profileNameInput.Text = name
                cfgStatus.Text = "📋 Selected: " .. name
                cfgStatus.TextColor3 = Color3.fromRGB(200, 200, 255)
            end)
        end
    end
    profileListFrame.CanvasSize = UDim2.new(0, 0, 0, profileListLayout.AbsoluteContentSize.Y + 8)
end

profileListCollapse.MouseButton1Click:Connect(function()
    profileListCollapsed = not profileListCollapsed
    profileListFrame.Visible = not profileListCollapsed
    if not profileListCollapsed then
        refreshProfileList()
        profileListCollapse.Text = "▲  Hide Saved Profiles"
    else
        profileListCollapse.Text = "▼  Show Saved Profiles"
    end
end)

ConfigTab:AddButton("🔄 Refresh List", Color3.fromRGB(55, 55, 70), function()
    refreshProfileList()
    cfgStatus.Text = "🔄 List refreshed"
    cfgStatus.TextColor3 = Color3.fromRGB(180, 180, 180)
end)

-- ── Save ──
ConfigTab:AddButton("💾 Save Profile", Color3.fromRGB(0, 130, 80), function()
    local name = profileNameInput.Text:match("^%s*(.-)%s*$")
    if name == "" then
        cfgStatus.Text = "❌ Enter a profile name"
        cfgStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end
    local ok, err = pcall(function()
        writefile(cfgPath(name), buildJSON())
    end)
    if ok then
        cfgStatus.Text = "✅ Saved: " .. name
        cfgStatus.TextColor3 = Color3.fromRGB(100, 220, 100)
    else
        cfgStatus.Text = "❌ Save failed"
        cfgStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
    end
end)

-- ── Load ──
ConfigTab:AddButton("📂 Load Profile", Color3.fromRGB(0, 100, 200), function()
    local name = profileNameInput.Text:match("^%s*(.-)%s*$")
    if name == "" then
        cfgStatus.Text = "❌ Enter a profile name"
        cfgStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end
    local path = cfgPath(name)
    local ok, src = pcall(readfile, path)
    if not ok or not src then
        cfgStatus.Text = "❌ Profile not found: " .. name
        cfgStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
        return
    end
    local ok2, err = pcall(function()
        applyConfig(parseJSON(src))
    end)
    if ok2 then
        cfgStatus.Text = "📂 Loaded: " .. name
        cfgStatus.TextColor3 = Color3.fromRGB(100, 200, 255)
    else
        cfgStatus.Text = "❌ Load parse error"
        cfgStatus.TextColor3 = Color3.fromRGB(255, 80, 80)
    end
end)

