BaseTab:AddToggle("Auto Upgrade", false, function(state)
    getgenv().AutoUpgrade = state
    if state then
        task.spawn(function()
            -- Cache remote once, fire inline (no per-slot task.spawn threads)
            local upgradeRemote = Remotes.BaseShared_UpgradeSlot
            local lastSlotCount = -1
            while getgenv().AutoUpgrade do
                local slots = getgenv().UpgradeSlots
                if slots and #slots > 0 then
                    for _, slot in ipairs(slots) do
                        if not getgenv().AutoUpgrade then break end
                        pcall(function() upgradeRemote:FireServer(slot) end)
                    end
                    -- Only update label when slot count changes, not every 0.5s
                    if #slots ~= lastSlotCount then
                        upgradeStatusLabel.Text = "⬆️ Upgrading " .. #slots .. " slot(s)"
                        upgradeStatusLabel.TextColor3 = Color3.fromRGB(100, 220, 100)
                        lastSlotCount = #slots
                    end
                else
                    if lastSlotCount ~= 0 then
                        upgradeStatusLabel.Text = "⚠️ No slots selected"
                        upgradeStatusLabel.TextColor3 = Color3.fromRGB(255, 180, 0)
                        lastSlotCount = 0
                    end
                end
                task.wait(0.5)
            end
            upgradeStatusLabel.Text = "⏹ Stopped"
            upgradeStatusLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
        end)
    else
        upgradeStatusLabel.Text = "⏹ Stopped"
        upgradeStatusLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
    end
end)

